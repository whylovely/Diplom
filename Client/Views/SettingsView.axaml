<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Client.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Client.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

  <StackPanel Spacing="20" MaxWidth="500">
    <TextBlock Text="Настройки" Classes="heading"/>

    <!-- Base Currency Card -->
    <Border Classes="card">
      <StackPanel Spacing="12">
        <TextBlock Text="Базовая валюта" Classes="subheading"/>
        
        <Panel>
          <!-- Show ComboBox if we have favorites -->
          <StackPanel Spacing="12" IsVisible="{Binding HasFavorites}">
            <TextBlock Text="Выберите базовую валюту из списка избранных." 
                       Classes="dim" TextWrapping="Wrap"/>
            
            <ComboBox ItemsSource="{Binding FavoriteCurrencies}"
                      SelectedItem="{Binding SelectedCurrency}"
                      Width="250" Height="40"
                      Background="#0D1120"
                      BorderBrush="#222845"
                      BorderThickness="1"
                      CornerRadius="8">
              <ComboBox.Styles>
                <Style Selector="ComboBox:focus /template/ Border#PART_BorderElement">
                  <Setter Property="BorderBrush" Value="#29B6F6"/>
                  <Setter Property="BoxShadow" Value="0 0 8 0 #4029B6F6"/>
                </Style>
                <Style Selector="ComboBox:pointerover /template/ Border#PART_BorderElement">
                  <Setter Property="BorderBrush" Value="#29B6F6"/>
                </Style>
              </ComboBox.Styles>
            </ComboBox>
          </StackPanel>

          <!-- Show Helper if NO favorites -->
          <StackPanel Spacing="12" IsVisible="{Binding !HasFavorites}">
            <TextBlock Text="Чтобы выбрать базовую валюту, сначала добавьте её в избранное." 
                       Classes="dim" TextWrapping="Wrap" Foreground="#9E9E9E"/>
            <Button Content="Перейти к валютам"
                    Command="{Binding GoToCurrenciesCommand}"
                    Classes="outline"
                    Width="200" Height="36"/>
          </StackPanel>
        </Panel>
      </StackPanel>
    </Border>

    <!-- Logout Card -->
    <Border Classes="card">
      <StackPanel Spacing="12">
        <TextBlock Text="Аккаунт" Classes="subheading"/>
        <TextBlock Text="Выйти из текущего аккаунта. Потребуется повторный вход." 
                   Classes="dim" TextWrapping="Wrap"/>
        <Button Content="🚪 Выйти из аккаунта"
                Command="{Binding LogoutCommand}"
                Classes="danger"
                Width="220" Height="36"/>
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
