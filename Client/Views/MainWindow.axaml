<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Client.ViewModels"
        xmlns:views="using:Client.Views"
        x:Class="Client.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        MinWidth="1000" MinHeight="650"
        Width="1100" Height="700"
        Title="FinanceApp">

  <Window.DataContext>
    <vm:MainWindowViewModel/>
  </Window.DataContext>

  <Window.DataTemplates>
    <DataTemplate DataType="vm:AccountsViewModel">
      <views:AccountsView/>
    </DataTemplate>
    <DataTemplate DataType="vm:CategoriesViewModel">
      <views:CategoriesView/>
    </DataTemplate>
    <DataTemplate DataType="vm:JournalViewModel">
      <views:JournalView/>
    </DataTemplate>
    <DataTemplate DataType="vm:NewTransactionViewModel">
      <views:NewTransactionView/>
    </DataTemplate>
    <DataTemplate DataType="vm:ReportViewModel">
      <views:ReportView/>
    </DataTemplate>
    <DataTemplate DataType="vm:ObligationsViewModel">
      <views:ObligationsView/>
    </DataTemplate>
    <DataTemplate DataType="vm:SettingsViewModel">
      <views:SettingsView/>
    </DataTemplate>
  </Window.DataTemplates>

  <Grid RowDefinitions="*,Auto">

    <!-- ═══ MAIN CONTENT AREA ══════════════════════════════════ -->
    <Border Grid.Row="0" Background="#080C1A" Padding="24,20,24,10">
      <ContentControl Content="{Binding Current}" />
    </Border>

    <!-- ═══ FLOATING BOTTOM NAV BAR + FAB ═════════════════════ -->
    <Grid Grid.Row="1" Margin="20,0,20,16" ColumnDefinitions="*,Auto">

      <!-- ── Pill navigation bar ──────────────────────────── -->
      <Border Grid.Column="0"
              CornerRadius="35"
              Background="#90101018"
              BorderBrush="#18FFFFFF"
              BorderThickness="1"
              Padding="6,3"
              BoxShadow="0 -2 20 0 #30000000"
              HorizontalAlignment="Stretch">

        <UniformGrid Columns="6">

          <!-- Счета -->
          <Button Command="{Binding NavigateAccountsCommand}"
                  Classes.navActive="{Binding IsAccountsActive}"
                  Classes="navItem"
                  HorizontalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" Spacing="1">
              <TextBlock Text="🏦" FontSize="16" HorizontalAlignment="Center"/>
              <TextBlock Text="Счета" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            </StackPanel>
          </Button>

          <!-- Категории -->
          <Button Command="{Binding NavigateCategoriesCommand}"
                  Classes.navActive="{Binding IsCategoriesActive}"
                  Classes="navItem"
                  HorizontalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" Spacing="1">
              <TextBlock Text="📂" FontSize="16" HorizontalAlignment="Center"/>
              <TextBlock Text="Категории" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            </StackPanel>
          </Button>

          <!-- Журнал -->
          <Button Command="{Binding NavigateJournalCommand}"
                  Classes.navActive="{Binding IsJournalActive}"
                  Classes="navItem"
                  HorizontalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" Spacing="1">
              <TextBlock Text="📋" FontSize="16" HorizontalAlignment="Center"/>
              <TextBlock Text="Журнал" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            </StackPanel>
          </Button>

          <!-- Отчёты -->
          <Button Command="{Binding NavigateReportCommand}"
                  Classes.navActive="{Binding IsReportActive}"
                  Classes="navItem"
                  HorizontalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" Spacing="1">
              <TextBlock Text="📊" FontSize="16" HorizontalAlignment="Center"/>
              <TextBlock Text="Отчёты" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            </StackPanel>
          </Button>

          <!-- Долги -->
          <Button Command="{Binding NavigateObligationsCommand}"
                  Classes.navActive="{Binding IsObligationsActive}"
                  Classes="navItem"
                  HorizontalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" Spacing="1">
              <TextBlock Text="🤝" FontSize="16" HorizontalAlignment="Center"/>
              <TextBlock Text="Долги" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            </StackPanel>
          </Button>

          <!-- Настройки -->
          <Button Command="{Binding NavigateSettingsCommand}"
                  Classes.navActive="{Binding IsSettingsActive}"
                  Classes="navItem"
                  HorizontalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" Spacing="1">
              <TextBlock Text="⚙️" FontSize="16" HorizontalAlignment="Center"/>
              <TextBlock Text="Настройки" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            </StackPanel>
          </Button>

        </UniformGrid>
      </Border>

      <!-- ── FAB «+» button (Новая операция) ──────────────── -->
      <Button Grid.Column="1"
              Command="{Binding NavigateNewTransactionCommand}"
              Width="48" Height="48"
              CornerRadius="24"
              Padding="0"
              Margin="10,0,0,0"
              BorderBrush="#18FFFFFF"
              BorderThickness="1"
              Background="Transparent"
              HorizontalContentAlignment="Center"
              VerticalContentAlignment="Center"
              VerticalAlignment="Center">
        <Button.Styles>
          <Style Selector="Button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#201E88C8"/>
          </Style>
        </Button.Styles>
        <TextBlock Text="+" FontSize="26" FontWeight="Light" HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="#80D8F0"/>
      </Button>

    </Grid>

  </Grid>
</Window>