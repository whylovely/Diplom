<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Client.ViewModels"
        xmlns:views="using:Client.Views"
        x:Class="Client.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        MinWidth="1000" MinHeight="650"
        Width="1100" Height="700"
        Title="FinanceApp">

  <Window.DataContext>
    <vm:MainWindowViewModel/>
  </Window.DataContext>

  <Window.DataTemplates>
    <DataTemplate DataType="vm:AccountsViewModel">
      <views:AccountsView/>
    </DataTemplate>
    <DataTemplate DataType="vm:CategoriesViewModel">
      <views:CategoriesView/>
    </DataTemplate>
    <DataTemplate DataType="vm:JournalViewModel">
      <views:JournalView/>
    </DataTemplate>
    <DataTemplate DataType="vm:NewTransactionViewModel">
      <views:NewTransactionView/>
    </DataTemplate>
    <DataTemplate DataType="vm:ReportViewModel">
      <views:ReportView/>
    </DataTemplate>
    <DataTemplate DataType="vm:ObligationsViewModel">
      <views:ObligationsView/>
    </DataTemplate>
    <DataTemplate DataType="vm:CurrenciesViewModel">
      <views:CurrenciesView/>
    </DataTemplate>
    <DataTemplate DataType="vm:SettingsViewModel">
      <views:SettingsView/>
    </DataTemplate>
  </Window.DataTemplates>

  <!-- Panel allows overlay layers on top of content -->
  <Panel>

    <!-- ═══ BASE LAYOUT: HEADER + CONTENT ══════════════════════ -->
    <Grid RowDefinitions="Auto,*">

      <!-- ─── HEADER BAR ──────────────────────────────────── -->
      <Border Grid.Row="0" Classes="headerBar" Padding="20,10">
        <Grid ColumnDefinitions="Auto,*,Auto">

          <!-- Hamburger / Close Button (LEFT) -->
          <Button Grid.Column="0" Command="{Binding ToggleMenuCommand}" Classes="hamburgerBtn">
            <Panel>
              <!-- Hamburger icon (3 lines) — visible when menu CLOSED -->
              <Path Data="M3,6H21V7.5H3V6M3,11.25H21V12.75H3V11.25M3,16.5H21V18H3V16.5Z"
                    Fill="{Binding $parent[Button].Foreground}" Stretch="Uniform" Width="20" Height="20"
                    IsVisible="{Binding !IsMenuOpen}"/>
              <!-- Cross icon — visible when menu OPEN -->
              <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                    Fill="{Binding $parent[Button].Foreground}" Stretch="Uniform" Width="18" Height="18"
                    IsVisible="{Binding IsMenuOpen}"/>
            </Panel>
          </Button>

          <!-- App Title (CENTER) -->
          <TextBlock Grid.Column="1" Text="FinanceApp" Classes="heading" FontSize="18"
                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>
      </Border>

      <!-- ─── MAIN CONTENT ────────────────────────────────── -->
      <Border Grid.Row="1" Background="#080C1A" Padding="24,20,24,24">
        <ContentControl Content="{Binding Current}" />
      </Border>

    </Grid>

    <!-- ═══ DIMMING OVERLAY ════════════════════════════════════ -->
    <!-- Covers entire window, click to close menu -->
    <Border Classes="dimOverlay" Classes.open="{Binding IsMenuOpen}"
            PointerPressed="OnOverlayPointerPressed"/>

    <!-- ═══ FLOATING GLASS MENU PANEL ══════════════════════════ -->
    <Border Classes="floatingMenuWrapper" Classes.open="{Binding IsMenuOpen}"
            VerticalAlignment="Top" HorizontalAlignment="Left"
            Margin="16,56,16,16" Width="300">

      <!-- Outer glow border -->
      <Border CornerRadius="20" ClipToBounds="True"
              BorderBrush="#18FFFFFF" BorderThickness="1"
              BoxShadow="0 8 32 0 #40000000, 0 0 0 1 #10FFFFFF">

        <!-- Acrylic glass material -->
        <ExperimentalAcrylicBorder CornerRadius="20">
          <ExperimentalAcrylicBorder.Material>
            <ExperimentalAcrylicMaterial BackgroundSource="Digger"
                                         TintColor="#0A0E1A"
                                         TintOpacity="0.15"
                                         MaterialOpacity="0.92" />
          </ExperimentalAcrylicBorder.Material>

          <StackPanel Spacing="4" Margin="12,16">

            <!-- Section label -->
            <TextBlock Text="НАВИГАЦИЯ" FontSize="10" FontWeight="Bold" Foreground="#55D8D8D8"
                       Margin="14,4,0,8" LetterSpacing="2"/>

            <!-- 1. Счета -->
            <Button Command="{Binding NavigateAccountsCommand}"
                    Classes="menuItem" Classes.menuItemActive="{Binding IsAccountsActive}">
              <StackPanel Orientation="Horizontal" Spacing="14">
                <Path Data="M4,3A2,2 0 0,0 2,5V19A2,2 0 0,0 4,21H20A2,2 0 0,0 22,19V5A2,2 0 0,0 20,3H4M4,5H20V8H15A3,3 0 0,0 12,11A3,3 0 0,0 15,14H20V19H4V5M15,10A1,1 0 0,1 16,11A1,1 0 0,1 15,12A1,1 0 0,1 14,11A1,1 0 0,1 15,10Z"
                      Fill="{Binding $parent[Button].Foreground}" Stretch="Uniform" Width="20" Height="20" VerticalAlignment="Center"/>
                <TextBlock Text="Счета" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <!-- 2. Категории -->
            <Button Command="{Binding NavigateCategoriesCommand}"
                    Classes="menuItem" Classes.menuItemActive="{Binding IsCategoriesActive}">
              <StackPanel Orientation="Horizontal" Spacing="14">
                <Path Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z"
                      Fill="{Binding $parent[Button].Foreground}" Stretch="Uniform" Width="20" Height="20" VerticalAlignment="Center"/>
                <TextBlock Text="Категории" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <!-- 3. Журнал -->
            <Button Command="{Binding NavigateJournalCommand}"
                    Classes="menuItem" Classes.menuItemActive="{Binding IsJournalActive}">
              <StackPanel Orientation="Horizontal" Spacing="14">
                <Path Data="M7,5H21V7H7V5M7,13V11H21V13H7M7,19H21V17H7V19M3,11H5V13H3V11M3,5H5V7H3V5M3,17H5V19H3V17Z"
                      Fill="{Binding $parent[Button].Foreground}" Stretch="Uniform" Width="20" Height="20" VerticalAlignment="Center"/>
                <TextBlock Text="Журнал" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <!-- Separator -->
            <Border Height="1" Background="#15FFFFFF" Margin="12,6"/>

            <!-- 4. + Транзакция (accent) -->
            <Button Command="{Binding NavigateNewTransactionCommand}"
                    Classes="menuItemAccent" Classes.menuItemActive="{Binding IsNewTransactionActive}">
              <StackPanel Orientation="Horizontal" Spacing="14">
                <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z"
                      Fill="{Binding $parent[Button].Foreground}" Stretch="Uniform" Width="20" Height="20" VerticalAlignment="Center"/>
                <TextBlock Text="Новая операция" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <!-- Separator -->
            <Border Height="1" Background="#15FFFFFF" Margin="12,6"/>

            <!-- 5. Отчёты -->
            <Button Command="{Binding NavigateReportCommand}"
                    Classes="menuItem" Classes.menuItemActive="{Binding IsReportActive}">
              <StackPanel Orientation="Horizontal" Spacing="14">
                <Path Data="M7,21H5V3H7V21M13,21H11V9H13V21M19,21H17V15H19V21Z"
                      Fill="{Binding $parent[Button].Foreground}" Stretch="Uniform" Width="20" Height="20" VerticalAlignment="Center"/>
                <TextBlock Text="Отчёты" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <!-- 6. Долги -->
            <Button Command="{Binding NavigateObligationsCommand}"
                    Classes="menuItem" Classes.menuItemActive="{Binding IsObligationsActive}">
              <StackPanel Orientation="Horizontal" Spacing="14">
                <Path Data="M16,11C17.66,11 19,9.66 19,8C19,6.34 17.66,5 16,5C14.34,5 13,6.34 13,8C13,9.66 14.34,11 16,11M16,13C13.67,13 9,14.17 9,16.5V19H23V16.5C23,14.17 18.33,13 16,13M8,11C9.66,11 11,9.66 11,8C11,6.34 9.66,5 8,5C6.34,5 5,6.34 5,8C5,9.66 6.34,11 8,11M8,13C5.67,13 1,14.17 1,16.5V19H7V16.5C7,15.34 7.6,14.07 9,13.25C8.61,13.09 8.28,13 8,13Z"
                      Fill="{Binding $parent[Button].Foreground}" Stretch="Uniform" Width="20" Height="20" VerticalAlignment="Center"/>
                <TextBlock Text="Долги" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <!-- Валюты -->
            <Button Command="{Binding NavigateCurrenciesCommand}"
                    Classes="menuItem" Classes.menuItemActive="{Binding IsCurrenciesActive}">
              <StackPanel Orientation="Horizontal" Spacing="14">
                <Path Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M11,7V8.08C9.5,8.3 8.35,9.58 8.12,11.1L10.09,11.45C10.22,10.66 10.82,10 11.5,10H12.5V13L11.5,13C9.57,13 8,14.57 8,16.5A2.5,2.5 0 0,0 10.5,19C10.7,19 10.86,18.96 11,18.92V20H13V18.92C14.5,18.7 15.65,17.42 15.88,15.9L13.91,15.55C13.78,16.34 13.18,17 12.5,17H11.5V14L12.5,14C14.43,14 16,12.43 16,10.5A2.5,2.5 0 0,0 13.5,8C13.3,8 13.14,8.04 13,8.08V7H11Z"
                      Fill="{Binding $parent[Button].Foreground}" Stretch="Uniform" Width="20" Height="20" VerticalAlignment="Center"/>
                <TextBlock Text="Валюты" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <!-- 7. Настройки -->
            <Button Command="{Binding NavigateSettingsCommand}"
                    Classes="menuItem" Classes.menuItemActive="{Binding IsSettingsActive}">
              <StackPanel Orientation="Horizontal" Spacing="14">
                <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.68 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"
                      Fill="{Binding $parent[Button].Foreground}" Stretch="Uniform" Width="20" Height="20" VerticalAlignment="Center"/>
                <TextBlock Text="Настройки" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

          </StackPanel>
        </ExperimentalAcrylicBorder>
      </Border>
    </Border>

  </Panel>
</Window>