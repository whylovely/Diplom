<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Client.ViewModels"
        xmlns:views="using:Client.Views"
        x:Class="Client.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        MinWidth="1000" MinHeight="650"
        Width="1000" Height="650"
        Title="FinanceApp">

  <Window.DataContext>
    <vm:MainWindowViewModel/>
  </Window.DataContext>

  <Window.DataTemplates>
    <DataTemplate DataType="vm:AccountsViewModel">
      <views:AccountsView/>
    </DataTemplate>

    <DataTemplate DataType="vm:CategoriesViewModel">
      <views:CategoriesView/>
    </DataTemplate>

    <DataTemplate DataType="vm:JournalViewModel">
      <views:JournalView/>
    </DataTemplate>

    <DataTemplate DataType="vm:NewTransactionViewModel">
      <views:NewTransactionView/>
    </DataTemplate>

    <DataTemplate DataType="vm:ReportViewModel">
      <views:ReportView/>
    </DataTemplate>

    <DataTemplate DataType="vm:ObligationsViewModel">
      <views:ObligationsView/>
    </DataTemplate>
  </Window.DataTemplates>

  <DockPanel>
    <StackPanel DockPanel.Dock="Left" Width="200" Spacing="8" Margin="12">
      <TextBlock Text="Навигация" FontSize="18"/>
      <Button Content="Счета" Command="{Binding NavigateAccountsCommand}"/>
      <Button Content="Категории" Command="{Binding NavigateCategoriesCommand}"/>
      <Button Content="Журнал" Command="{Binding NavigateJournalCommand}"/>
      <Button Content="Отчеты" Command="{Binding NavigateReportCommand}"/>
      <Button Content="Долги" Command="{Binding NavigateObligationsCommand}"/>
      <Button Content="Новая операция" Command="{Binding NavigateNewTransactionCommand}"/>
    </StackPanel>

    <ContentControl Content="{Binding Current}" />
  </DockPanel>
</Window>