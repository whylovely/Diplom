<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Client.ViewModels"
        xmlns:views="using:Client.Views"
        x:Class="Client.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        MinWidth="1000" MinHeight="650"
        Width="1100" Height="700"
        Title="FinanceApp">

  <Window.DataContext>
    <vm:MainWindowViewModel/>
  </Window.DataContext>

  <Window.DataTemplates>
    <DataTemplate DataType="vm:AccountsViewModel">
      <views:AccountsView/>
    </DataTemplate>
    <DataTemplate DataType="vm:CategoriesViewModel">
      <views:CategoriesView/>
    </DataTemplate>
    <DataTemplate DataType="vm:JournalViewModel">
      <views:JournalView/>
    </DataTemplate>
    <DataTemplate DataType="vm:NewTransactionViewModel">
      <views:NewTransactionView/>
    </DataTemplate>
    <DataTemplate DataType="vm:ReportViewModel">
      <views:ReportView/>
    </DataTemplate>
    <DataTemplate DataType="vm:ObligationsViewModel">
      <views:ObligationsView/>
    </DataTemplate>
    <DataTemplate DataType="vm:SettingsViewModel">
      <views:SettingsView/>
    </DataTemplate>
  </Window.DataTemplates>

  <Grid RowDefinitions="*,Auto">

    <!-- ═══ MAIN CONTENT AREA ══════════════════════════════════ -->
    <Border Grid.Row="0" Background="#0B1021" Padding="24,20,24,10">
      <ContentControl Content="{Binding Current}" />
    </Border>

    <!-- ═══ FLOATING BOTTOM NAV BAR + FAB ═════════════════════ -->
    <Grid Grid.Row="1" Margin="20,0,20,16" ColumnDefinitions="*,Auto">

      <!-- ── Pill navigation bar ──────────────────────────── -->
      <Border Grid.Column="0"
              CornerRadius="35"
              Background="#E61C1C1E"
              BorderBrush="#2A3150"
              BorderThickness="1"
              Padding="8,4"
              HorizontalAlignment="Stretch">

        <UniformGrid Columns="6">

          <!-- Счета -->
          <Button Command="{Binding NavigateAccountsCommand}"
                  Classes.navActive="{Binding IsAccountsActive}"
                  Classes="navItem"
                  HorizontalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" Spacing="2">
              <TextBlock Text="🏦" FontSize="18" HorizontalAlignment="Center"/>
              <TextBlock Text="Счета" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            </StackPanel>
          </Button>

          <!-- Категории -->
          <Button Command="{Binding NavigateCategoriesCommand}"
                  Classes.navActive="{Binding IsCategoriesActive}"
                  Classes="navItem"
                  HorizontalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" Spacing="2">
              <TextBlock Text="📂" FontSize="18" HorizontalAlignment="Center"/>
              <TextBlock Text="Категории" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            </StackPanel>
          </Button>

          <!-- Журнал -->
          <Button Command="{Binding NavigateJournalCommand}"
                  Classes.navActive="{Binding IsJournalActive}"
                  Classes="navItem"
                  HorizontalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" Spacing="2">
              <TextBlock Text="📋" FontSize="18" HorizontalAlignment="Center"/>
              <TextBlock Text="Журнал" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            </StackPanel>
          </Button>

          <!-- Отчёты -->
          <Button Command="{Binding NavigateReportCommand}"
                  Classes.navActive="{Binding IsReportActive}"
                  Classes="navItem"
                  HorizontalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" Spacing="2">
              <TextBlock Text="📊" FontSize="18" HorizontalAlignment="Center"/>
              <TextBlock Text="Отчёты" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            </StackPanel>
          </Button>

          <!-- Долги -->
          <Button Command="{Binding NavigateObligationsCommand}"
                  Classes.navActive="{Binding IsObligationsActive}"
                  Classes="navItem"
                  HorizontalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" Spacing="2">
              <TextBlock Text="🤝" FontSize="18" HorizontalAlignment="Center"/>
              <TextBlock Text="Долги" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            </StackPanel>
          </Button>

          <!-- Настройки -->
          <Button Command="{Binding NavigateSettingsCommand}"
                  Classes.navActive="{Binding IsSettingsActive}"
                  Classes="navItem"
                  HorizontalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" Spacing="2">
              <TextBlock Text="⚙️" FontSize="18" HorizontalAlignment="Center"/>
              <TextBlock Text="Настройки" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            </StackPanel>
          </Button>

        </UniformGrid>
      </Border>

      <!-- ── FAB «+» button (Новая операция) ──────────────── -->
      <Button Grid.Column="1"
              Command="{Binding NavigateNewTransactionCommand}"
              Width="56" Height="56"
              CornerRadius="28"
              Padding="0"
              Margin="12,0,0,0"
              BorderThickness="0"
              HorizontalContentAlignment="Center"
              VerticalContentAlignment="Center"
              VerticalAlignment="Center">
        <Button.Background>
          <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Color="#29B6F6" Offset="0"/>
            <GradientStop Color="#AA00FF" Offset="1"/>
          </LinearGradientBrush>
        </Button.Background>
        <Button.Styles>
          <Style Selector="Button:pointerover /template/ ContentPresenter">
            <Setter Property="Background">
              <Setter.Value>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                  <GradientStop Color="#4FC3F7" Offset="0"/>
                  <GradientStop Color="#CE93D8" Offset="1"/>
                </LinearGradientBrush>
              </Setter.Value>
            </Setter>
          </Style>
        </Button.Styles>
        <TextBlock Text="➕" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="#FFFFFF"/>
      </Button>

    </Grid>

  </Grid>
</Window>