<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Client.ViewModels"
             xmlns:dg="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.DataGrid"
             x:Class="Client.Views.CategoriesView"
             x:DataType="vm:CategoriesViewModel">
             
  <Grid RowDefinitions="Auto,*">
    <StackPanel Grid.Row="0" Spacing="16" Margin="0,0,0,16">
      <!-- Header -->
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Text="Категории" Classes="heading"/>
        <Button Grid.Column="1" Content="＋ Добавить"
                Classes="accent"
                Command="{Binding AddCommand}"
                Width="160"/>
      </Grid>
    </StackPanel>

    <!-- Categories Table -->
    <dg:DataGrid Grid.Row="1" x:Name="CategoriesGrid"
                 ItemsSource="{Binding Categories}"
                 SelectedItem="{Binding Selected}"
                 AutoGenerateColumns="False"
                 IsReadOnly="True"
                 BorderThickness="0"
                 Background="Transparent"
                 GridLinesVisibility="Horizontal">

          <dg:DataGrid.ContextMenu>
            <ContextMenu x:CompileBindings="False">
              <MenuItem Header="Переименовать" Command="{Binding RenameCommand}" />
              <MenuItem Header="Удалить" Command="{Binding DeleteCommand}" />
            </ContextMenu>
          </dg:DataGrid.ContextMenu>

          <dg:DataGrid.Columns>
            <dg:DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="600"/>
          </dg:DataGrid.Columns>
    </dg:DataGrid>
  </Grid>
</UserControl>