<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Client.ViewModels.DialogWindow"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="550"
        x:Class="Client.Views.DialogViews.CurrencySelectionDialog"
        x:DataType="vm:CurrencySelectionViewModel"
        Width="400" Height="550"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ExtendClientAreaToDecorationsHint="True"
        Background="Transparent"
        TransparencyLevelHint="AcrylicBlur">

  <Window.Styles>
    <!-- Skeleton Animation -->
    <Style Selector="Border.skeleton">
      <Setter Property="Background" Value="#1AFFFFFF"/>
      <Style.Animations>
        <Animation Duration="0:0:1.5" IterationCount="Infinite" PlaybackDirection="Alternate">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="0.3"/>
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="0.8"/>
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
  </Window.Styles>

  <!-- Glassmorphism Container -->
  <Border CornerRadius="16" 
          Background="#0D1120"
          BorderBrush="#2A2F45" BorderThickness="1"
          Margin="10">
      
    <Grid RowDefinitions="Auto, Auto, *, Auto">
      
      <!-- Header -->
      <TextBlock Grid.Row="0" Text="Выбор валюты" 
                 Foreground="White" FontSize="20" FontWeight="SemiBold"
                 Margin="24,24,24,16"/>

      <!-- Search Box -->
      <TextBox Grid.Row="1" 
               Text="{Binding SearchText, Mode=TwoWay}"
               Watermark="Поиск валюты (USD, Bitcoin)..."
               Background="#1AFFFFFF"
               Foreground="White"
               CaretBrush="#29B6F6"
               BorderThickness="1"
               BorderBrush="Transparent"
               CornerRadius="10"
               Padding="12,10"
               Margin="24,0,24,16">
        
        <TextBox.Styles>
          <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#29B6F6"/>
            <Setter Property="BoxShadow" Value="0 0 8 0 #4029B6F6"/>
          </Style>
        </TextBox.Styles>

        <TextBox.InnerLeftContent>
          <PathIcon Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" 
                    Width="18" Height="18" Margin="12,0,4,0" 
                    Foreground="#9E9E9E"/>
        </TextBox.InnerLeftContent>
        
        <TextBox.InnerRightContent>
          <Button Command="{Binding ClearSearchCommand}"
                  IsVisible="{Binding SearchText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                  Background="Transparent" BorderThickness="0" Padding="8">
            <PathIcon Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"
                      Width="16" Height="16" Foreground="#9E9E9E"/>
          </Button>
        </TextBox.InnerRightContent>
      </TextBox>

      <!-- Skeleton Loader -->
      <ItemsControl Grid.Row="2" IsVisible="{Binding IsSearching}" Margin="24,0,24,24" ItemsSource="{Binding DummyItems}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,16">
              <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" Classes="skeleton" Margin="0,0,16,0"/>
              <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                <Border Width="120" Height="14" CornerRadius="4" Classes="skeleton" HorizontalAlignment="Left"/>
                <Border Width="80" Height="10" CornerRadius="4" Classes="skeleton" HorizontalAlignment="Left"/>
              </StackPanel>
              <Border Grid.Column="2" Width="24" Height="24" CornerRadius="12" Classes="skeleton"/>
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- Main List -->
      <ListBox Grid.Row="2" 
               ItemsSource="{Binding Currencies}" 
               IsVisible="{Binding !IsSearching}"
               Background="Transparent"
               BorderThickness="0"
               Margin="16,0,16,0"
               SelectionMode="Single">
        
        <ListBox.ItemsPanel>
          <ItemsPanelTemplate>
            <VirtualizingStackPanel />
          </ItemsPanelTemplate>
        </ListBox.ItemsPanel>
        
        <ListBox.Styles>
          <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
          </Style>
          <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1AFFFFFF"/>
          </Style>
        </ListBox.Styles>

        <ListBox.ItemTemplate>
          <DataTemplate>
            <Button Command="{Binding SelectCommand}" 
                    Background="Transparent" BorderThickness="0"
                    Padding="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
              <Grid ColumnDefinitions="Auto,*,Auto" Background="Transparent">
                
                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" Background="#1AFFFFFF" Margin="0,0,12,0">
                  <TextBlock Text="{Binding Code, StringFormat=\{0:1\}}" 
                             VerticalAlignment="Center" HorizontalAlignment="Center"
                             Foreground="#29B6F6" FontWeight="Bold"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock Text="{Binding Code}" Foreground="White" FontWeight="Bold" FontSize="16"/>
                  <TextBlock Text="{Binding FullName}" Foreground="#9E9E9E" FontSize="13"/>
                </StackPanel>

                <Button Grid.Column="2" 
                        Command="{Binding ToggleFavoriteCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        ZIndex="1">
                  <PathIcon Width="24" Height="24" 
                            Data="{Binding FavoriteIconData}"
                            Foreground="{Binding FavoriteColor}"/>
                </Button>
              </Grid>
            </Button>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <Button Grid.Row="3" Content="Закрыть" Command="{Binding CloseCommand}"
              Margin="24,16,24,24" HorizontalAlignment="Right" Classes="outline"/>

    </Grid>
  </Border>
</Window>