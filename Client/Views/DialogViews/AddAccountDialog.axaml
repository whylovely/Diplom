<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Client.ViewModels"
        x:Class="Client.Views.AddAccountDialog"
        x:DataType="vm:AddAccountDialogViewModel"
        Width="460" Height="420"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#0B1021"
        Title="Добавить счёт">

  <Border Classes="card" Margin="16">
    <StackPanel Spacing="14">

      <TextBlock Text="Добавить счёт" Classes="subheading"/>

      <StackPanel Spacing="4">
        <TextBlock Text="Название счёта" Classes="dim"/>
        <TextBox Text="{Binding Name}" Watermark="Например: Основной счёт" />
      </StackPanel>

      <StackPanel Spacing="4">
        <TextBlock Text="Основная валюта" Classes="dim"/>
        <TextBox Text="{Binding BaseCurrency, Mode=OneWay}" IsReadOnly="True" IsEnabled="False" Width="220" HorizontalAlignment="Left"/>
      </StackPanel>

      <StackPanel Spacing="4">
        <TextBlock Text="Начальный баланс" Classes="dim"/>
        <TextBox Text="{Binding InitialBalance}" Watermark="0" />
      </StackPanel>

      <CheckBox Content="Многовалютный счёт"
                IsChecked="{Binding IsMultiCurrency}" />

      <StackPanel Spacing="4" IsVisible="{Binding IsMultiCurrency}">
        <TextBlock Text="Дополнительная валюта" Classes="dim"/>
        <ComboBox ItemsSource="{Binding SecondaryCurrencies}"
                  SelectedItem="{Binding SelectedSecondaryCurrency}"
                  Width="220" />
      </StackPanel>

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
        <Button Content="✓ Создать" Classes="accent" IsEnabled="{Binding CanOk}" Click="OnOkClick" Width="110"/>
        <Button Content="Отмена" Click="OnCancelClick" Width="100"/>
      </StackPanel>

    </StackPanel>
  </Border>
</Window>
