<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Client.ViewModels"
        x:Class="Client.Views.AddAccountDialog"
        x:DataType="vm:AddAccountDialogViewModel"
        Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#0B1021"
        Title="Добавить счёт">

  <Border Classes="card" Margin="16">
    <StackPanel Spacing="14">

      <TextBlock Text="Добавить счёт" Classes="subheading"/>

      <StackPanel Spacing="4">
        <TextBlock Text="Название счёта" Classes="dim"/>
        <TextBox Text="{Binding Name}" Watermark="Например: Основной счёт" />
        <TextBlock Text="Название не может быть пустым" 
                   Foreground="#FF5252" FontSize="12" IsVisible="{Binding HasNameError}" />
      </StackPanel>

      <StackPanel Spacing="4">
        <TextBlock Text="Валюта счёта" Classes="dim"/>
        <Grid ColumnDefinitions="Auto,*">
          <TextBlock Grid.Column="0" Text="💵" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
          <AutoCompleteBox Grid.Column="1"
                           ItemsSource="{Binding Currencies}"
                           Text="{Binding SelectedCurrency, Mode=TwoWay}"
                           FilterMode="Contains"
                           Watermark="Введите валюту (RUB, USD, EUR...)"
                           Width="188"/>
        </Grid>
      </StackPanel>

      <StackPanel Spacing="4">
        <TextBlock Text="Начальный баланс" Classes="dim"/>
        <NumericUpDown Value="{Binding InitialBalance}" FormatString="N2" ShowButtonSpinner="False" AllowSpin="False" Watermark="0" />
        <TextBlock Text="Начальный остаток не может быть отрицательным" 
        Foreground="#FF5252" FontSize="12" IsVisible="{Binding IsBalanceNegative}" />
      </StackPanel>

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
        <Button Content="✓ Создать" Classes="accent" IsEnabled="{Binding CanOk}" Click="OnOkClick" Width="110"/>
        <Button Content="Отмена" Click="OnCancelClick" Width="100"/>
      </StackPanel>

    </StackPanel>
  </Border>
</Window>