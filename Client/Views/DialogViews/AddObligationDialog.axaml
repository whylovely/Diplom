<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Client.ViewModels.DialogWindow"
        x:Class="Client.Views.AddObligationDialog"
        x:DataType="vm:AddObligationDialogViewModel"
        Width="450" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#0B1021"
        Title="{Binding Title}">
  
  <Border Classes="card" Margin="16">
    <StackPanel Spacing="12">

      <TextBlock Text="{Binding Title}" Classes="subheading"/>

      <StackPanel Spacing="4">
        <TextBlock Text="Контрагент" Classes="dim"/>
        <TextBox Text="{Binding Counterparty}" Watermark="Имя или название компании" Classes.error="{Binding HasCounterpartyError}" />
      </StackPanel>

      <StackPanel Spacing="4">
        <TextBlock Text="Сумма" Classes="dim"/>
        <NumericUpDown Value="{Binding Amount}" Minimum="0.01" FormatString="N2" Classes.error="{Binding HasAmountError}" />
      </StackPanel>

      <StackPanel Spacing="4">
        <TextBlock Text="Валюта" Classes="dim"/>
        <Grid ColumnDefinitions="Auto,*">
          <TextBlock Grid.Column="0" Text="💵" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
          <AutoCompleteBox Grid.Column="1"
                           ItemsSource="{Binding Currencies}"
                           Text="{Binding CurrencyCode, Mode=TwoWay}"
                           FilterMode="Contains"
                           Watermark="Введите валюту (USD, EUR...)"
                           Width="188" HorizontalAlignment="Left"/>
        </Grid>
      </StackPanel>

      <StackPanel Spacing="4">
        <TextBlock Text="Тип обязательства" Classes="dim"/>
        <StackPanel Orientation="Horizontal" Spacing="16">
          <RadioButton Content="Должен" IsChecked="{Binding IsDebt}" GroupName="ObligationTypeGroup" />
          <RadioButton Content="Должны" IsChecked="{Binding IsCredit}" GroupName="ObligationTypeGroup" />
        </StackPanel>
      </StackPanel>

      <StackPanel Spacing="4">
        <TextBlock Text="Дата погашения" Classes="dim"/>
        <DatePicker SelectedDate="{Binding DueDate}" HorizontalAlignment="Stretch" Classes.error="{Binding HasDueDateError}"/>
      </StackPanel>

      <StackPanel Spacing="4">
        <TextBlock Text="Заметка (необязательно)" Classes="dim"/>
        <TextBox Text="{Binding Note}" AcceptsReturn="True" Height="60" Watermark="Дополнительная информация" />
      </StackPanel>

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,6,0,0">
        <Button Content="✓ Сохранить" Classes="accent" Command="{Binding SaveCommand}" IsDefault="True" Width="120"/>
        <Button Content="Отмена" Command="{Binding CancelCommand}" IsCancel="True" Width="100"/>
      </StackPanel>

    </StackPanel>
  </Border>
</Window>