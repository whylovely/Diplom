<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Client.ViewModels.DialogWindow"
        x:Class="Client.Views.AddObligationDialog"
        x:DataType="vm:AddObligationDialogViewModel"
        Width="450" Height="560"
        WindowStartupLocation="CenterOwner"
        Background="#0B1021"
        Title="{Binding Title}">
  
  <Border Classes="card" Margin="16">
    <StackPanel Spacing="12">

      <TextBlock Text="{Binding Title}" Classes="subheading"/>

      <StackPanel Spacing="4">
        <TextBlock Text="Контрагент" Classes="dim"/>
        <TextBox Text="{Binding Counterparty}" Watermark="Имя или название компании" />
      </StackPanel>

      <StackPanel Spacing="4">
        <TextBlock Text="Сумма" Classes="dim"/>
        <NumericUpDown Value="{Binding Amount}" Minimum="0.01" FormatString="N2" />
      </StackPanel>

      <StackPanel Spacing="4">
        <TextBlock Text="Валюта" Classes="dim"/>
        <ComboBox ItemsSource="{Binding Currencies}" SelectedItem="{Binding CurrencyCode}" HorizontalAlignment="Stretch" />
      </StackPanel>

      <StackPanel Spacing="4">
        <TextBlock Text="Тип обязательства" Classes="dim"/>
        <ComboBox ItemsSource="{Binding Types}" SelectedItem="{Binding Type}" HorizontalAlignment="Stretch">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding}" />
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
      </StackPanel>

      <StackPanel Spacing="4">
        <TextBlock Text="Дата погашения (необязательно)" Classes="dim"/>
        <DatePicker SelectedDate="{Binding DueDate}" HorizontalAlignment="Stretch"/>
      </StackPanel>

      <StackPanel Spacing="4">
        <TextBlock Text="Заметка" Classes="dim"/>
        <TextBox Text="{Binding Note}" AcceptsReturn="True" Height="60" Watermark="Дополнительная информация" />
      </StackPanel>

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,6,0,0">
        <Button Content="✓ Сохранить" Classes="accent" Command="{Binding SaveCommand}" IsDefault="True" Width="120"/>
        <Button Content="Отмена" Command="{Binding CancelCommand}" IsCancel="True" Width="100"/>
      </StackPanel>

    </StackPanel>
  </Border>
</Window>
