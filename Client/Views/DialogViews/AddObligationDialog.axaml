<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Client.ViewModels.DialogWindow"
        x:Class="Client.Views.AddObligationDialog"
        x:DataType="vm:AddObligationDialogViewModel"
        Width="450" Height="450"
        WindowStartupLocation="CenterOwner"
        Title="{Binding Title}">
  
  <StackPanel Margin="20" Spacing="10">
    <TextBlock Text="Контрагент" />
    <TextBox Text="{Binding Counterparty}" Watermark="Имя или название компании" />

    <TextBlock Text="Сумма" />
    <NumericUpDown Value="{Binding Amount}" Minimum="0.01" FormatString="N2" />

    <TextBlock Text="Валюта" />
    <ComboBox ItemsSource="{Binding Currencies}" SelectedItem="{Binding CurrencyCode}" HorizontalAlignment="Stretch" />

    <TextBlock Text="Тип обязательства" />
    <ComboBox ItemsSource="{Binding Types}" SelectedItem="{Binding Type}" HorizontalAlignment="Stretch">
      <ComboBox.ItemTemplate>
        <DataTemplate>
          <TextBlock Text="{Binding}" />
        </DataTemplate>
      </ComboBox.ItemTemplate>
    </ComboBox>

    <TextBlock Text="Дата погашения (необязательно)" />
    <DatePicker SelectedDate="{Binding DueDate}" HorizontalAlignment="Stretch"/>

    <TextBlock Text="Заметка" />
    <TextBox Text="{Binding Note}" AcceptsReturn="True" Height="60" Watermark="Дополнительная информация" />

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,20,0,0">
      <Button Content="Сохранить" Command="{Binding SaveCommand}" IsDefault="True" />
      <Button Content="Отмена" Command="{Binding CancelCommand}" IsCancel="True" />
    </StackPanel>
  </StackPanel>
</Window>
