<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Client.ViewModels"
        x:Class="Client.Views.AddCategoryDialog"
        x:DataType="vm:AddCategoryDialogViewModel"
        Width="420" Height="200"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Title="Добавить категорию">

  <StackPanel Margin="16" Spacing="12">
    <TextBlock Text="Название категории:"/>

    <TextBox Text="{Binding Name}" Watermark="Например: Коммуналка" />

    <TextBlock Text="Тип категории" />
    <ComboBox ItemsSource="{Binding KindItems}"
              SelectedItem="{Binding SelectedKind}"
              Width="220">
      <ComboBox.ItemTemplate>
        <DataTemplate x:DataType="vm:AddCategoryDialogViewModel+KindItem">
          <TextBlock Text="{Binding Title}" />
        </DataTemplate>
      </ComboBox.ItemTemplate>
    </ComboBox>

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,-56,0,0">
    <Button Content="OK" IsEnabled="{Binding CanOk}" Click="OnOkClick" />
    <Button Content="Отмена" Click="OnCancelClick" />
  </StackPanel>
      </StackPanel>
</Window>
