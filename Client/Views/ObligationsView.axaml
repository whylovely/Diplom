<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Client.ViewModels"
             x:Class="Client.Views.ObligationsView"
             x:DataType="vm:ObligationsViewModel">
  
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="10">
      <TextBlock Text="Обязательства" FontSize="22"/>

      <StackPanel Orientation="Horizontal" Spacing="10">
        <Button Content="Добавить" Command="{Binding AddCommand}" Width="120" />
        <Button Content="Изменить" Command="{Binding EditCommand}" Width="120" />
        <Button Content="Удалить" Command="{Binding DeleteCommand}" Width="120" />
        <Button Content="Статус" Command="{Binding MarkPaidCommand}" Width="120" ToolTip.Tip="Переключить статус оплачено/активно" />
        
        <CheckBox IsChecked="{Binding ShowPaid}" Content="Показывать оплаченные" VerticalAlignment="Center" Margin="10,0"/>
      </StackPanel>

      <Border Background="#F0F0F0" CornerRadius="5" Padding="10" Margin="0,5">
        <StackPanel Orientation="Horizontal" Spacing="20">
          <TextBlock Text="{Binding TotalDebt, StringFormat='Я должен: {0:N2}'}" Foreground="#D13438" FontWeight="Bold" FontSize="16" />
          <TextBlock Text="{Binding TotalCredit, StringFormat='Мне должны: {0:N2}'}" Foreground="#107C10" FontWeight="Bold" FontSize="16" />
        </StackPanel>
      </Border>

      <DataGrid ItemsSource="{Binding Items}" 
                SelectedItem="{Binding SelectedItem}"
                AutoGenerateColumns="False" 
                IsReadOnly="True" 
                Height="450"
                GridLinesVisibility="Horizontal">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Контрагент" Binding="{Binding Counterparty}" Width="200" />
          
          <DataGridTemplateColumn Header="Сумма" Width="120">
            <DataTemplate>
              <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right">
                <TextBlock Text="{Binding Amount, StringFormat={}{0:N2}}" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Currency}" Foreground="Gray" />
              </StackPanel>
            </DataTemplate>
          </DataGridTemplateColumn>

          <DataGridTextColumn Header="Тип" Binding="{Binding TypeLabel}" Width="100" />
          
          <DataGridTextColumn Header="Срок" Binding="{Binding DueDate, StringFormat={}{0:dd.MM.yyyy}}" Width="100" />
          
          <DataGridTemplateColumn Header="Статус" Width="100">
            <DataTemplate>
              <TextBlock Text="{Binding StatusLabel}">
                <TextBlock.Styles>
                  <Style Selector="TextBlock[Text=Погашено]">
                    <Setter Property="Foreground" Value="Gray"/>
                  </Style>
                  <Style Selector="TextBlock[Text=Просрочено]">
                    <Setter Property="Foreground" Value="Red"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                  </Style>
                  <Style Selector="TextBlock[Text=Активно]">
                    <Setter Property="Foreground" Value="Green"/>
                  </Style>
                </TextBlock.Styles>
              </TextBlock>
            </DataTemplate>
          </DataGridTemplateColumn>
          
          <DataGridTextColumn Header="Примечание" Binding="{Binding Note}" Width="*" />
        </DataGrid.Columns>
      </DataGrid>

    </StackPanel>
  </ScrollViewer>
</UserControl>
