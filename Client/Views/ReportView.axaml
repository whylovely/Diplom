
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Client.ViewModels"
             xmlns:m="using:Client.Models"
             xmlns:views="using:Client.Views"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             x:Class="Client.Views.ReportView"
             x:DataType="vm:ReportViewModel">

    <Grid RowDefinitions="Auto, *">

        <!-- ── Header Bar ─────────────────────────────────────── -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="Отчёты" Classes="heading" VerticalAlignment="Center" Margin="0,0,24,0"/>
                <TextBlock Text="Раздел:" VerticalAlignment="Center" Classes="dim" Margin="0,6,0,0"/>
                <ComboBox ItemsSource="{Binding SectionItems}"
                          SelectedItem="{Binding SelectedSectionItem}"
                          Width="280"
                          Margin="0,4,0,0">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:ReportViewModel+SectionItem">
                            <TextBlock Text="{Binding Title}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
            
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                <Button Classes="dockItem" ToolTip.Tip="Экспорт отчёта">
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuItem Header="Сохранить как CSV..." Command="{Binding ExportCommand}" CommandParameter="CSV" />
                            <MenuItem Header="Сохранить как TXT..." Command="{Binding ExportCommand}" CommandParameter="TXT" />
                            <MenuItem Header="Сохранить как Excel..." Command="{Binding ExportCommand}" CommandParameter="Excel" />
                        </MenuFlyout>
                    </Button.Flyout>
                    <!-- Download/Export Icon -->
                    <Path Data="M5 20h14v-2H5m14-9h-4V3H9v6H5l7 7 7-7z" 
                          Fill="{Binding $parent[Button].Foreground}" Stretch="Uniform" Width="20" Height="20" />
                </Button>
            </StackPanel>
        </Grid>

        <Panel Grid.Row="1">

            <!-- ══ SUMMARY ════════════════════════════════════ -->
            <Grid IsVisible="{Binding IsSummary}" RowDefinitions="Auto, Auto, *">
                <!-- Date Filter -->
                <Border Grid.Row="0" Classes="cardSmall" Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="С:" VerticalAlignment="Center" Classes="dim"/>
                        <DatePicker SelectedDate="{Binding DateFrom}" Width="300"/>
                        <TextBlock Text="По:" VerticalAlignment="Center" Classes="dim"/>
                        <DatePicker SelectedDate="{Binding DateTo}" Width="300"/>
                        <Button Content="Обновить" Command="{Binding RefreshSummaryCommand}" Classes="accent"/>
                    </StackPanel>
                </Border>

                <!-- Summary Cards -->
                <Grid Grid.Row="1" ColumnDefinitions="*,*,*" Margin="0,0,0,12">
                    <Border Classes="cardSmall" Margin="0,0,6,0">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Доходы" Classes="dim"/>
                            <TextBlock Text="{Binding TotalIncome, StringFormat={}{0:N2}}" Classes="moneyGreen" FontSize="20"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Classes="cardSmall" Margin="6,0">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Расходы" Classes="dim"/>
                            <TextBlock Text="{Binding TotalExpense, StringFormat={}{0:N2}}" Classes="moneyRed" FontSize="20"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Classes="cardSmall" Margin="6,0,0,0">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Итог" Classes="dim"/>
                            <TextBlock Text="{Binding Net, StringFormat={}{0:N2}}" Classes="cyan" FontSize="20"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid> 

            <!-- ══ BALANCE AT DATE ════════════════════════════ -->
            <Grid IsVisible="{Binding IsBalanceAtDate}" RowDefinitions="Auto, *">
                <Border Grid.Row="0" Classes="cardSmall" Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="Дата:" VerticalAlignment="Center" Classes="dim"/>
                        <DatePicker SelectedDate="{Binding BalanceDate}" Width="300"/>
                        <Button Content="Обновить" Command="{Binding RefreshBalanceCommand}" Classes="accent"/>
                        <TextBlock Text="{Binding TotalAssetsAtDate, StringFormat=Итого: {0:N2}}" 
                                   VerticalAlignment="Center" FontWeight="Bold" Foreground="#29B6F6" Margin="16,0,0,0"/>
                    </StackPanel>
                </Border>

                <DataGrid Grid.Row="1" ItemsSource="{Binding BalanceRows}" AutoGenerateColumns="False" IsReadOnly="True"
                          Background="Transparent" BorderThickness="0"
                          GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Счёт" Binding="{Binding AccountName}" Width="*"/>
                            <DataGridTextColumn Header="Валюта" Binding="{Binding CurrencyCode}" Width="90"/>
                            <DataGridTemplateColumn Header="Остаток" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Balance, StringFormat={}{0:N2}}" Classes="amount" VerticalAlignment="Center" Margin="4,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- ══ MONTHLY DYNAMICS ═══════════════════════════ -->
           <Grid IsVisible="{Binding IsMonthlyDynamics}" RowDefinitions="Auto, *, *">
                <Border Grid.Row="0" Classes="cardSmall" Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                       <TextBlock Text="С:" VerticalAlignment="Center" Classes="dim"/>
                       <DatePicker SelectedDate="{Binding DateFrom}" Width="300"/>
                       <TextBlock Text="По:" VerticalAlignment="Center" Classes="dim"/>
                       <DatePicker SelectedDate="{Binding DateTo}" Width="300"/>
                       <Button Content="Обновить" Command="{Binding RefreshMonthlyCommand}" Classes="accent"/>
                    </StackPanel>
                </Border>
                
                <DataGrid Grid.Row="1" ItemsSource="{Binding MonthlyRows}" AutoGenerateColumns="False" IsReadOnly="True" Background="Transparent" BorderThickness="0" Margin="0,0,0,12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Месяц" Binding="{Binding Month}" Width="150"/>
                            <DataGridTemplateColumn Header="Доходы" Width="*">
                                <DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding Income, StringFormat={}{0:N2}}" Classes="moneyGreen" VerticalAlignment="Center" Margin="4,0"/></DataTemplate></DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Расходы" Width="*">
                                <DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding Expense, StringFormat={}{0:N2}}" Classes="moneyRed" VerticalAlignment="Center" Margin="4,0"/></DataTemplate></DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Итог" Width="*">
                                <DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding Net, StringFormat={}{0:N2}}" Classes="amount" VerticalAlignment="Center" Margin="4,0"/></DataTemplate></DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                </DataGrid>

                <lvc:CartesianChart Grid.Row="2" Series="{Binding MonthlySeries}"
                                    XAxes="{Binding XAxes}"
                                    YAxes="{Binding YAxes}" />
            </Grid> 

            <!-- ══ ACCOUNTS TURNOVER ══════════════════════════ -->
            <Grid IsVisible="{Binding IsAccountsTurnover}" RowDefinitions="Auto, *">
                <Border Grid.Row="0" Classes="cardSmall" Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                       <TextBlock Text="С:" VerticalAlignment="Center" Classes="dim"/>
                       <DatePicker SelectedDate="{Binding DateFrom}" Width="300"/>
                       <TextBlock Text="По:" VerticalAlignment="Center" Classes="dim"/>
                       <DatePicker SelectedDate="{Binding DateTo}" Width="300"/>
                       <Button Content="Обновить" Command="{Binding RefreshAccountsCommand}" Classes="accent"/>
                    </StackPanel>
                </Border>

                <DataGrid Grid.Row="1" ItemsSource="{Binding AccountRows}" AutoGenerateColumns="False" IsReadOnly="True" Background="Transparent" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Счёт" Binding="{Binding AccountName}" Width="*"/>
                            <DataGridTextColumn Header="Валюта" Binding="{Binding CurrencyCode}" Width="80"/>
                            <DataGridTemplateColumn Header="Начало" Width="100">
                                <DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding Opening, StringFormat={}{0:N2}}" Classes="amount" VerticalAlignment="Center" Margin="4,0"/></DataTemplate></DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Доходы" Width="120">
                                <DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding DebitTurnOver, StringFormat={}{0:N2}}" Classes="moneyGreen" VerticalAlignment="Center" Margin="4,0"/></DataTemplate></DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Расходы" Width="120">
                                <DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding CreditTurnOver, StringFormat={}{0:N2}}" Classes="moneyRed" VerticalAlignment="Center" Margin="4,0"/></DataTemplate></DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Конец" Width="100">
                                <DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding Closing, StringFormat={}{0:N2}}" Classes="amount" VerticalAlignment="Center" Margin="4,0"/></DataTemplate></DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- ══ EXPENSE TOP ════════════════════════════════ -->
            <Grid IsVisible="{Binding IsExpenseTop}" RowDefinitions="Auto, *, *">
                <Border Grid.Row="0" Classes="cardSmall" Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="С:" VerticalAlignment="Center" Classes="dim"/>
                        <DatePicker SelectedDate="{Binding DateFrom}" Width="300"/>
                        <TextBlock Text="По:" VerticalAlignment="Center" Classes="dim"/>
                        <DatePicker SelectedDate="{Binding DateTo}" Width="300"/>
                        <TextBlock Text="Топ:" VerticalAlignment="Center" Classes="dim"/>
                        <NumericUpDown Minimum="1" Maximum="20" Value="{Binding TopN}" Width="100"/>
                        <Button Content="Обновить" Command="{Binding RefreshExpenseTopCommand}" Classes="accent"/>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding TopExpensesSum, StringFormat=Сумма: {0:N2}}" Foreground="#FF5252"/>
                            <TextBlock Text="{Binding TopExpensesShare, StringFormat=Доля: {0}%}" Foreground="#9E9E9E"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <DataGrid Grid.Row="1" ItemsSource="{Binding ExpenseShareRows}" AutoGenerateColumns="False" IsReadOnly="True" Background="Transparent" BorderThickness="0" Margin="0,0,0,12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Категория" Binding="{Binding CategoryName}" Width="*"/>
                            <DataGridTemplateColumn Header="Сумма" Width="150">
                                <DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding Total, StringFormat={}{0:N2}}" Classes="moneyRed" VerticalAlignment="Center" Margin="4,0"/></DataTemplate></DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Доля, %" Width="100">
                                <DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding SharePercent, StringFormat={}{0:P2}}" Classes="amount" VerticalAlignment="Center" Margin="4,0"/></DataTemplate></DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                </DataGrid>

                <lvc:PieChart Grid.Row="2" Series="{Binding ExpensePieSeries}" />
            </Grid>

            <!-- ══ INCOME TOP ═════════════════════════════════ -->
            <Grid IsVisible="{Binding IsIncomeTop}" RowDefinitions="Auto, *, *">
                <Border Grid.Row="0" Classes="cardSmall" Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="С:" VerticalAlignment="Center" Classes="dim"/>
                        <DatePicker SelectedDate="{Binding DateFrom}" Width="300"/>
                        <TextBlock Text="По:" VerticalAlignment="Center" Classes="dim"/>
                        <DatePicker SelectedDate="{Binding DateTo}" Width="300"/>
                        <TextBlock Text="Топ:" VerticalAlignment="Center" Classes="dim"/>
                        <NumericUpDown Minimum="1" Maximum="20" Value="{Binding TopN}" Width="100"/>
                        <Button Content="Обновить" Command="{Binding RefreshIncomeTopCommand}" Classes="accent"/>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding TopIncomesSum, StringFormat=Сумма: {0:N2}}" Foreground="#00E676"/>
                            <TextBlock Text="{Binding TopIncomesShare, StringFormat=Доля: {0}%}" Foreground="#9E9E9E"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <DataGrid Grid.Row="1" ItemsSource="{Binding IncomeShareRows}" AutoGenerateColumns="False" IsReadOnly="True" Background="Transparent" BorderThickness="0" Margin="0,0,0,12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Категория" Binding="{Binding CategoryName}" Width="*"/>
                            <DataGridTemplateColumn Header="Сумма" Width="150">
                                <DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding Total, StringFormat={}{0:N2}}" Classes="moneyGreen" VerticalAlignment="Center" Margin="4,0"/></DataTemplate></DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Доля, %" Width="100">
                                <DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding SharePercent, StringFormat={}{0:P2}}" Classes="amount" VerticalAlignment="Center" Margin="4,0"/></DataTemplate></DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                </DataGrid>

                <lvc:PieChart Grid.Row="2" Series="{Binding IncomePieSeries}" />
            </Grid>

            <!-- ══ EXPENSE BY CATEGORY ════════════════════════ -->
           <Grid IsVisible="{Binding IsExpenseByCategory}" RowDefinitions="Auto, Auto, *">
                <Border Grid.Row="0" Classes="cardSmall" Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="С:" VerticalAlignment="Center" Classes="dim"/>
                       <DatePicker SelectedDate="{Binding DateFrom}" Width="300"/>
                       <TextBlock Text="По:" VerticalAlignment="Center" Classes="dim"/>
                       <DatePicker SelectedDate="{Binding DateTo}" Width="300"/>
                       <Button Content="Обновить" Command="{Binding RefreshExpenseCategoryCommand}" Classes="accent"/>
                    </StackPanel>
                </Border>
                
                <TextBlock Grid.Row="1" Text="{Binding TotalExpense, StringFormat=Итого расходов: {0:N2}}" 
                           FontSize="16" Margin="0,0,0,8" Classes="moneyRed"/>

                <ScrollViewer Grid.Row="2">
                        <ItemsControl ItemsSource="{Binding ExpenseGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="m:CategoryDetailGroup">
                                    <Expander Margin="0,2" HorizontalAlignment="Stretch">
                                        <Expander.Header>
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Text="{Binding CategoryName}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Total, StringFormat={}{0:N2}}" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Expander.Header>
                                        <DataGrid ItemsSource="{Binding Days}" AutoGenerateColumns="False"
                                                  IsReadOnly="True" HeadersVisibility="Column" Background="Transparent" BorderThickness="0"
                                                  MaxHeight="400">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Дата" Binding="{Binding Date}" Width="120" FontFamily="Fira Code, Consolas, monospace"/>
                                                <DataGridTemplateColumn Header="Сумма" Width="130">
                                                    <DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding Amount, StringFormat={}{0:N2}}" Classes="moneyRed" VerticalAlignment="Center" Margin="4,0"/></DataTemplate></DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Expander>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- ══ INCOME BY CATEGORY ═════════════════════════ -->
            <Grid IsVisible="{Binding IsIncomeByCategory}" RowDefinitions="Auto, Auto, *">
                <Border Grid.Row="0" Classes="cardSmall" Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="С:" VerticalAlignment="Center" Classes="dim"/>
                       <DatePicker SelectedDate="{Binding DateFrom}" Width="300"/>
                       <TextBlock Text="По:" VerticalAlignment="Center" Classes="dim"/>
                       <DatePicker SelectedDate="{Binding DateTo}" Width="300"/>
                       <Button Content="Обновить" Command="{Binding RefreshIncomeCategoryCommand}" Classes="accent"/>
                    </StackPanel>
                </Border>

                <TextBlock Grid.Row="1" Text="{Binding TotalIncome, StringFormat=Итого доходов: {0:N2}}" 
                           FontSize="16" Margin="0,0,0,8" Classes="moneyGreen"/>

                <ScrollViewer Grid.Row="2">
                        <ItemsControl ItemsSource="{Binding IncomeGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="m:CategoryDetailGroup">
                                    <Expander Margin="0,2" HorizontalAlignment="Stretch">
                                        <Expander.Header>
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Text="{Binding CategoryName}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Total, StringFormat={}{0:N2}}" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Expander.Header>
                                        <DataGrid ItemsSource="{Binding Days}" AutoGenerateColumns="False"
                                                  IsReadOnly="True" HeadersVisibility="Column" Background="Transparent" BorderThickness="0"
                                                  MaxHeight="400">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Дата" Binding="{Binding Date}" Width="120" FontFamily="Fira Code, Consolas, monospace"/>
                                                <DataGridTemplateColumn Header="Сумма" Width="130">
                                                    <DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding Amount, StringFormat={}{0:N2}}" Classes="moneyGreen" VerticalAlignment="Center" Margin="4,0"/></DataTemplate></DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Expander>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- ══ CALENDAR ═════════════════════════════════════ -->
            <Grid IsVisible="{Binding IsCalendar}">
                <views:CalendarView DataContext="{Binding CalendarVm}"/>
            </Grid>

        </Panel>
    </Grid>
</UserControl>