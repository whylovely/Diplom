<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Client.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Client.Views.CurrenciesView"
             x:DataType="vm:CurrenciesViewModel">

  <UserControl.Styles>
    <Style Selector="Border.skeleton">
      <Setter Property="Background" Value="#1AFFFFFF"/>
      <Style.Animations>
        <Animation Duration="0:0:1.5" IterationCount="Infinite" PlaybackDirection="Alternate">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="0.3"/>
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="0.8"/>
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto, Auto, *">
    
    <!-- Заголовок -->
    <StackPanel Grid.Row="0" Margin="0,0,0,24">
      <TextBlock Text="Валюты" Classes="heading"/>
      <TextBlock Text="Просмотр курсов относительно базовой валюты и управление избранным." 
                 Classes="dim" Margin="0,4,0,0"/>
    </StackPanel>

    <!-- Строка поиска -->
    <TextBox Grid.Row="1" 
             Text="{Binding SearchText, Mode=TwoWay}"
             Watermark="Поиск валюты (код или название)..."
             Background="#1AFFFFFF"
             Foreground="White"
             CaretBrush="#29B6F6"
             BorderThickness="1"
             BorderBrush="Transparent"
             CornerRadius="10"
             Padding="12,12"
             Margin="0,0,0,16"
             MaxWidth="500"
             HorizontalAlignment="Left">
      
      <TextBox.Styles>
        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
          <Setter Property="BorderBrush" Value="#29B6F6"/>
          <Setter Property="BoxShadow" Value="0 0 8 0 #4029B6F6"/>
        </Style>
      </TextBox.Styles>

      <TextBox.InnerLeftContent>
        <PathIcon Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" 
                  Width="18" Height="18" Margin="12,0,4,0" Foreground="#9E9E9E"/>
      </TextBox.InnerLeftContent>
      
      <TextBox.InnerRightContent>
        <Button Command="{Binding ClearSearchCommand}"
                IsVisible="{Binding SearchText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                Background="Transparent" BorderThickness="0" Padding="8">
          <PathIcon Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"
                    Width="16" Height="16" Foreground="#9E9E9E"/>
        </Button>
      </TextBox.InnerRightContent>
    </TextBox>

    <ItemsControl Grid.Row="2" IsVisible="{Binding IsSearching}" Margin="0,8,0,0" ItemsSource="{Binding DummyItems}">
      <ItemsControl.ItemTemplate>
        <DataTemplate>
          <Border Classes="card" Margin="0,0,0,12" Padding="16">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
              <Border Grid.Column="0" Width="48" Height="48" CornerRadius="24" Classes="skeleton" Margin="0,0,16,0"/>
              <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="8">
                <Border Width="150" Height="16" CornerRadius="4" Classes="skeleton" HorizontalAlignment="Left"/>
                <Border Width="100" Height="12" CornerRadius="4" Classes="skeleton" HorizontalAlignment="Left"/>
              </StackPanel>
              <Border Grid.Column="2" Width="100" Height="20" CornerRadius="4" Classes="skeleton" Margin="0,0,24,0" VerticalAlignment="Center"/>
              <Border Grid.Column="3" Width="24" Height="24" CornerRadius="12" Classes="skeleton" VerticalAlignment="Center"/>
            </Grid>
          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

    <!-- Основной список с виртуализацией -->
    <ListBox Grid.Row="2" 
             ItemsSource="{Binding Currencies}" 
             IsVisible="{Binding !IsSearching}"
             Background="Transparent"
             BorderThickness="0"
             SelectionMode="Single"
             Margin="0,8,0,0">
      
      <ListBox.ItemsPanel>
        <ItemsPanelTemplate>
          <VirtualizingStackPanel />
        </ItemsPanelTemplate>
      </ListBox.ItemsPanel>
      
      <ListBox.Styles>
        <Style Selector="ListBoxItem">
          <Setter Property="Padding" Value="0"/>
          <Setter Property="Margin" Value="0,0,0,12"/>
          <Setter Property="CornerRadius" Value="12"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
          <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
          <Setter Property="Background" Value="Transparent"/>
        </Style>
      </ListBox.Styles>

      <ListBox.ItemTemplate>
        <DataTemplate>
          <Border Classes="card"
                  Background="{DynamicResource SurfaceBrush}"
                  Padding="16">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
              
              <!-- Иконка/Аватар валюты -->
              <Border Grid.Column="0" Width="48" Height="48" CornerRadius="24" Background="#1AFFFFFF" Margin="0,0,16,0">
                <TextBlock Text="{Binding Code, StringFormat=\{0:1\}}" 
                           VerticalAlignment="Center" HorizontalAlignment="Center"
                           Foreground="#29B6F6" FontWeight="Bold" FontSize="20"/>
              </Border>

              <!-- Текстовая информация -->
              <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="{Binding Code}" Foreground="White" FontWeight="Bold" FontSize="18"/>
                <TextBlock Text="{Binding FullName}" Foreground="#9E9E9E" FontSize="14" Margin="0,4,0,0"/>
              </StackPanel>

              <!-- Курс -->
              <TextBlock Grid.Column="2" Text="{Binding FormattedRate}" 
                         VerticalAlignment="Center" Margin="0,0,24,0" 
                         FontWeight="SemiBold" Foreground="#E0E0E0" FontSize="15"/>

              <!-- Кнопка Избранное (Звездочка) -->
              <Button Grid.Column="3" 
                      Command="{Binding ToggleFavoriteCommand}"
                      Background="Transparent"
                      BorderThickness="0"
                      Cursor="Hand"
                      Padding="8">
                <PathIcon Width="28" Height="28" 
                          Data="{Binding FavoriteIconData}"
                          Foreground="{Binding FavoriteColor}"/>
              </Button>
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

  </Grid>
</UserControl>