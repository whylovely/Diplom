<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Client.ViewModels"
             x:Class="Client.Views.NewTransactionView"
             x:DataType="vm:NewTransactionViewModel">

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="16" MaxWidth="600">

      <TextBlock Text="Новая операция" Classes="heading"/>

      <Border Classes="cardSmall">
        <StackPanel Orientation="Horizontal" Spacing="20">
          <RadioButton Content="Расход"
                       IsChecked="{Binding IsExpense}"
                       Command="{Binding SetExpenseCommand}"
                       Foreground="#FF5252"/>
          <RadioButton Content="Доход"
                       IsChecked="{Binding IsIncome}"
                       Command="{Binding SetIncomeCommand}"
                       Foreground="#00E676"/>
          <RadioButton Content="Перевод"
                       IsChecked="{Binding IsTransfer}"
                       Command="{Binding SetTransferCommand}"
                       Foreground="#29B6F6"/>
          <RadioButton Content="Отдал долг"
                       IsChecked="{Binding IsDebtRepayment}"
                       Command="{Binding SetDebtRepaymentCommand}"
                       Foreground="#FFB74D"/>
          <RadioButton Content="Мне вернули"
                       IsChecked="{Binding IsDebtReceive}"
                       Command="{Binding SetDebtReceiveCommand}"
                       Foreground="#BA68C8"/>
        </StackPanel>
      </Border>

      <Border Classes="card">
        <StackPanel Spacing="14">

          <StackPanel Spacing="4">
            <TextBlock Text="Дата" Classes="dim"/>
            <DatePicker SelectedDate="{Binding Date}" Width="400" HorizontalAlignment="Left"/>
          </StackPanel>

          <StackPanel Spacing="4">
            <TextBlock Text="Описание" Classes="dim"/>
            <TextBox Text="{Binding Description}" Width="400" HorizontalAlignment="Left"/>
          </StackPanel>

          <StackPanel Spacing="4"
                      IsVisible="{Binding IsSingleAccount}">
            <TextBlock Text="Счёт" Classes="dim"/>
            <ComboBox ItemsSource="{Binding Accounts}"
                      SelectedItem="{Binding FromAccount}"
                      Width="400" HorizontalAlignment="Left">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                    <TextBlock Text="|" Foreground="Gray" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Balance, StringFormat={}{0:N2}}" Foreground="#A0A0A0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding CurrencyCode}" Foreground="#A0A0A0" VerticalAlignment="Center" />
                  </StackPanel>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </StackPanel>

          <StackPanel Spacing="4"
                      IsVisible="{Binding IsTransfer}">
            <TextBlock Text="Откуда" Classes="dim"/>
            <ComboBox ItemsSource="{Binding Accounts}"
                      SelectedItem="{Binding FromAccount}"
                      Width="400" HorizontalAlignment="Left">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                    <TextBlock Text="|" Foreground="Gray" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Balance, StringFormat={}{0:N2}}" Foreground="#A0A0A0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding CurrencyCode}" Foreground="#A0A0A0" VerticalAlignment="Center" />
                  </StackPanel>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </StackPanel>

          <StackPanel Spacing="4"
                      IsVisible="{Binding IsTransfer}">
            <TextBlock Text="Куда" Classes="dim"/>
            <ComboBox ItemsSource="{Binding Accounts}"
                      SelectedItem="{Binding ToAccount}"
                      Width="400" HorizontalAlignment="Left">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                    <TextBlock Text="|" Foreground="Gray" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Balance, StringFormat={}{0:N2}}" Foreground="#A0A0A0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding CurrencyCode}" Foreground="#A0A0A0" VerticalAlignment="Center" />
                  </StackPanel>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </StackPanel>

          <StackPanel Spacing="4"
                      IsVisible="{Binding IsCategoryRequire}">
            <TextBlock Text="Категория" Classes="dim"/>
            <ComboBox ItemsSource="{Binding FilteredCategories}"
                      SelectedItem="{Binding Category}"
                      Width="400" HorizontalAlignment="Left">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Name}"/>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </StackPanel>

          <StackPanel Spacing="4"
                      IsVisible="{Binding IsObligationRequire}">
            <TextBlock Text="Долг" Classes="dim"/>
            <ComboBox ItemsSource="{Binding ActiveObligations}"
                      SelectedItem="{Binding SelectedObligation}"
                      Width="400" HorizontalAlignment="Left">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{Binding Counterparty}" VerticalAlignment="Center" FontWeight="SemiBold" />
                    <TextBlock Text="|" Foreground="Gray" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Amount, StringFormat={}{0:N2}}" Foreground="#A0A0A0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Currency}" Foreground="#A0A0A0" VerticalAlignment="Center" />
                  </StackPanel>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </StackPanel>

          <StackPanel Spacing="4">
            <TextBlock Text="Сумма" Classes="dim"/>
            <NumericUpDown Value="{Binding Amount}" Minimum="0" FormatString="N2" ShowButtonSpinner="False" AllowSpin="False" Width="400" HorizontalAlignment="Left" FontFamily="Fira Code, Consolas, monospace" FontFeatures="tnum, zero"/>
          </StackPanel>

          <Separator/>

          <Button Content="✓ Провести"
                  Classes="accent"
                  Command="{Binding PostCommand}"
                  Width="180"
                  HorizontalAlignment="Left"/>

        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>