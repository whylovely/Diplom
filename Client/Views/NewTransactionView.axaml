<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Client.ViewModels"
             x:Class="Client.Views.NewTransactionView"
             x:DataType="vm:NewTransactionViewModel">

  <StackPanel Spacing="12">

    <TextBlock Text="Новая операция"
               FontSize="22"
               FontWeight="Bold"/>

    <StackPanel Orientation="Horizontal" Spacing="16">
        <RadioButton Content="Расход"
                     IsChecked="{Binding IsExpense}"
                     Command="{Binding SetExpenseCommand}" />

        <RadioButton Content="Доход"
                     IsChecked="{Binding IsIncome}"
                     Command="{Binding SetIncomeCommand}" />

        <RadioButton Content="Перевод"
                     IsChecked="{Binding IsTransfer}"
                     Command="{Binding SetTransferCommand}" />
    </StackPanel>

    <Separator/>

    <StackPanel Orientation="Horizontal" Spacing="10">
      <TextBlock Text="Дата:" Width="90"/>
      <DatePicker SelectedDate="{Binding Date}" Width="300"/>
    </StackPanel>

    <StackPanel Orientation="Horizontal" Spacing="10">
      <TextBlock Text="Описание:" Width="90"/>
      <TextBox Text="{Binding Description}" Width="400"/>
    </StackPanel>

    <StackPanel Orientation="Horizontal"
                Spacing="10"
                IsVisible="{Binding IsSingleAccount}">
      <TextBlock Text="Счет:" Width="90"/>
      <ComboBox ItemsSource="{Binding Accounts}"
                SelectedItem="{Binding FromAccount}"
                Width="260">
        <ComboBox.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding Name}"/>
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
    </StackPanel>

    <StackPanel Orientation="Horizontal"
                Spacing="10"
                IsVisible="{Binding IsTransfer}">
      <TextBlock Text="Откуда:" Width="90"/>
      <ComboBox ItemsSource="{Binding Accounts}"
                SelectedItem="{Binding FromAccount}"
                Width="260">
        <ComboBox.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding Name}"/>
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
    </StackPanel>

    <StackPanel Orientation="Horizontal"
                Spacing="10"
                IsVisible="{Binding IsTransfer}">
      <TextBlock Text="Куда:" Width="90"/>
      <ComboBox ItemsSource="{Binding Accounts}"
                SelectedItem="{Binding ToAccount}"
                Width="260">
        <ComboBox.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding Name}"/>
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
    </StackPanel>

    <StackPanel Orientation="Horizontal"
                Spacing="10"
                IsVisible="{Binding IsCategoryRequire}">
      <TextBlock Text="Категория:" Width="90"/>
      <ComboBox ItemsSource="{Binding FilteredCategories}"
                SelectedItem="{Binding Category}"
                Width="260">
        <ComboBox.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding Name}"/>
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
    </StackPanel>

    <StackPanel Orientation="Horizontal" Spacing="10">
      <TextBlock Text="Сумма:" Width="90"/>
      <TextBox Text="{Binding Amount}" Width="200"/>
    </StackPanel>

    <Separator/>

    <Button Content="Провести"
            Command="{Binding PostCommand}"
            Width="160"
            HorizontalAlignment="Left"/>

  </StackPanel>
</UserControl>
