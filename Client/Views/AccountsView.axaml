<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Client.ViewModels"
             x:Class="Client.Views.AccountsView"
             x:DataType="vm:AccountsViewModel">

  <Grid RowDefinitions="Auto,*">
    <StackPanel Grid.Row="0" Spacing="16" Margin="0,0,0,16">
      
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0" Spacing="4">
            <TextBlock Text="Общий баланс" Classes="dim"/>
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,16">
                <TextBlock Text="{Binding TotalBalance, StringFormat={}{0:N2}}" Classes="heroBalance"/>
                <TextBlock Text="{Binding BaseCurrencyCode}" Classes="heroBalance" FontSize="28" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
            </StackPanel>
        </StackPanel>
        
        <StackPanel Grid.Column="1" VerticalAlignment="Top" Spacing="12" HorizontalAlignment="Right">
            
            <Button Command="{Binding SyncCommand}"
                    Background="Transparent" BorderThickness="0" Padding="0"
                    Cursor="Hand" ToolTip.Tip="Синхронизировать с сервером"
                    HorizontalAlignment="Right">
              <Border Padding="8,6" CornerRadius="16" Background="#151A2E">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <Path Data="{Binding SyncIconData}" 
                        Fill="{Binding SyncIconColor}" 
                        Width="16" Height="16" Stretch="Uniform"
                        Classes.syncing="{Binding IsSyncing}">
                    <Path.Styles>
                      <Style Selector="Path.syncing">
                        <Style.Animations>
                          <Animation Duration="0:0:1.5" IterationCount="Infinite">
                            <KeyFrame Cue="0%">
                              <Setter Property="Opacity" Value="1.0"/>
                            </KeyFrame>
                            <KeyFrame Cue="50%">
                              <Setter Property="Opacity" Value="0.4"/>
                            </KeyFrame>
                            <KeyFrame Cue="100%">
                              <Setter Property="Opacity" Value="1.0"/>
                            </KeyFrame>
                          </Animation>
                        </Style.Animations>
                      </Style>
                    </Path.Styles>
                  </Path>
                  <TextBlock Text="{Binding SyncStatusText}" Classes="dim" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
              </Border>
            </Button>

            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="＋ Группа"
                      Command="{Binding AddGroupCommand}"
                      Padding="10,6"
                      FontSize="12"/>
              <Button Content="＋ Счёт"
                      Classes="accent"
                      Command="{Binding AddAccountCommand}"
                      Padding="14,6"
                      FontSize="12"/>
            </StackPanel>
        </StackPanel>
      </Grid>
      
      <TextBlock Text="Ваши счета" Classes="heading"/>
    </StackPanel>

    <ScrollViewer Grid.Row="1" IsVisible="{Binding !IsLoading}">
      <ItemsControl ItemsSource="{Binding Groups}">
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="vm:AccountGroupViewModel">
            <StackPanel Spacing="8" Margin="0,0,0,24">
              
              <!-- Group Header -->
              <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                  <TextBlock Text="{Binding Name}" Classes="subheading" VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding TotalBalance, StringFormat={}{0:N2}}" 
                             Classes="dim" FontWeight="Bold" VerticalAlignment="Center"
                             IsVisible="{Binding !!Accounts.Count}"/>
                  <TextBlock Text="{Binding BaseCurrency}" Classes="dim" FontSize="10" VerticalAlignment="Center"
                             IsVisible="{Binding !!Accounts.Count}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                  <Button Background="Transparent" BorderThickness="0" Padding="4"
                          Command="{Binding $parent[UserControl].DataContext.RenameGroupCommand}"
                          CommandParameter="{Binding}"
                          IsVisible="{Binding Group, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <Path Data="M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z" 
                          Fill="#606060" Width="14" Height="14" Stretch="Uniform"/>
                  </Button>
                  <Button Background="Transparent" BorderThickness="0" Padding="4"
                          Command="{Binding $parent[UserControl].DataContext.DeleteGroupCommand}"
                          CommandParameter="{Binding}"
                          IsVisible="{Binding Group, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19V4M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" 
                          Fill="#606060" Width="14" Height="14" Stretch="Uniform"/>
                  </Button>
                </StackPanel>
              </Grid>

              <!-- Accounts in Group -->
              <ItemsControl ItemsSource="{Binding Accounts}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Classes="cardSmall" Width="260" Margin="0,0,12,12">
                      <Border.ContextMenu>
                        <ContextMenu x:CompileBindings="False">
                          <MenuItem Header="Переименовать" 
                                    Command="{Binding $parent[UserControl].DataContext.RenameAccountCommand}" 
                                    CommandParameter="{Binding}" />
                          <MenuItem Header="Удалить" 
                                    Command="{Binding $parent[UserControl].DataContext.DeleteAccountCommand}" 
                                    CommandParameter="{Binding}" />
                          <MenuItem Header="Переместить в группу..." 
                                    Command="{Binding $parent[UserControl].DataContext.MoveToGroupCommand}" 
                                    CommandParameter="{Binding}" />
                          <Separator/>
                          <MenuItem Header="Быстрый расход" 
                                    Command="{Binding $parent[UserControl].DataContext.QuickExpenseCommand}" 
                                    CommandParameter="{Binding}" />
                          <MenuItem Header="Быстрый доход" 
                                    Command="{Binding $parent[UserControl].DataContext.QuickIncomeCommand}" 
                                    CommandParameter="{Binding}" />
                        </ContextMenu>
                      </Border.ContextMenu>
                      
                      <Grid RowDefinitions="Auto,Auto"
                            PointerPressed="OnAccountPointerPressed">
                        <StackPanel Grid.Row="0" Spacing="2">
                          <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                          <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="{Binding Balance, StringFormat={}{0:N2}}" Classes="amount" FontSize="18"/>
                            <TextBlock Text="{Binding CurrencyCode}" Classes="dim" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                          </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="0,8,0,0" Spacing="2" IsVisible="{Binding IsMultiCurrency}">
                          <Separator Margin="0,4"/>
                          <StackPanel Orientation="Horizontal" Spacing="4">
                             <TextBlock Text="{Binding SecondaryBalance, StringFormat={}{0:N2}}" Classes="amount" FontSize="14" Opacity="0.7"/>
                             <TextBlock Text="{Binding SecondaryCurrencyCode}" Classes="dim" FontSize="12" VerticalAlignment="Bottom"/>
                          </StackPanel>
                        </StackPanel>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16"
                IsVisible="{Binding !Accounts.Count}">
      <StackPanel.IsVisible>
        <MultiBinding Converter="{x:Static BoolConverters.And}">
          <Binding Path="!Accounts.Count"/>
          <Binding Path="!IsLoading"/>
        </MultiBinding>
      </StackPanel.IsVisible>
      <Path Data="M19,3H5C3.89,3 3,3.89 3,5V19C3,20.1 3.9,21 5,21H19C20.1,21 21,20.1 21,19V5C21,3.89 20.1,3 19,3M19,19H5V5H19V19M17,17H7V15H17V17M17,13H7V11H17V13M17,9H7V7H17V9Z" 
            Fill="#9E9E9E" Opacity="0.15" Width="120" Height="120" Stretch="Uniform" HorizontalAlignment="Center"/>
      <TextBlock Text="Здесь пока нет счетов..." Classes="dim" FontSize="16" HorizontalAlignment="Center"/>
    </StackPanel>
  </Grid>
</UserControl>