<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Client.ViewModels"
             x:Class="Client.Views.AccountsView"
             x:DataType="vm:AccountsViewModel">

  <Grid RowDefinitions="Auto,*">
    <StackPanel Grid.Row="0" Spacing="16" Margin="0,0,0,16">
      <!-- Header -->
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0" Spacing="4">
            <TextBlock Text="Общий баланс" Classes="dim"/>
            <TextBlock Text="{Binding TotalBalance, StringFormat={}{0:C2}}" Classes="heroBalance" Margin="0,0,0,16"/>
        </StackPanel>
        
        <StackPanel Grid.Column="1" VerticalAlignment="Top" Spacing="16" HorizontalAlignment="Right">
            
            <!-- Sync Indicator -->
            <Border Padding="8,6" CornerRadius="16" Background="#151A2E" HorizontalAlignment="Right">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Path Data="{Binding SyncIconData}" 
                      Fill="{Binding SyncIconColor}" 
                      Width="16" Height="16" Stretch="Uniform"
                      Classes.syncing="{Binding IsSyncing}">
                  <Path.Styles>
                    <Style Selector="Path.syncing">
                      <Style.Animations>
                        <Animation Duration="0:0:1.5" IterationCount="Infinite">
                          <KeyFrame Cue="0%">
                            <Setter Property="Opacity" Value="1.0"/>
                          </KeyFrame>
                          <KeyFrame Cue="50%">
                            <Setter Property="Opacity" Value="0.4"/>
                          </KeyFrame>
                          <KeyFrame Cue="100%">
                            <Setter Property="Opacity" Value="1.0"/>
                          </KeyFrame>
                        </Animation>
                      </Style.Animations>
                    </Style>
                  </Path.Styles>
                </Path>
                <TextBlock Text="{Binding SyncStatusText}" Classes="dim" FontSize="12" VerticalAlignment="Center"/>
              </StackPanel>
            </Border>

            <Button Content="＋ Добавить счёт"
                    Classes="accent"
                    Command="{Binding AddAccountCommand}"
                    Width="180"/>
        </StackPanel>
      </Grid>
      
      <TextBlock Text="Ваши счета" Classes="heading"/>
    </StackPanel>

    <!-- Skeleton Loading -->
    <StackPanel Grid.Row="1" Spacing="8" IsVisible="{Binding IsLoading}" Margin="0,16,0,0">
      <Border Classes="skeleton animating" Height="40" Margin="0,0,0,8"/>
      <Border Classes="skeleton animating" Height="40" Margin="0,0,0,8"/>
      <Border Classes="skeleton animating" Height="40" Margin="0,0,0,8"/>
      <Border Classes="skeleton animating" Height="40" Margin="0,0,0,8"/>
      <Border Classes="skeleton animating" Height="40" Margin="0,0,0,8"/>
    </StackPanel>

    <!-- Accounts Table -->
    <DataGrid Grid.Row="1" x:Name="AccountsGrid"
              ItemsSource="{Binding Accounts}"
              SelectedItem="{Binding SelectedAccount}"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              BorderThickness="0"
              Background="Transparent"
              GridLinesVisibility="Horizontal"
              IsVisible="{Binding !IsLoading}">

          <DataGrid.ContextMenu>
            <ContextMenu x:CompileBindings="False">
              <MenuItem Header="Переименовать" Command="{Binding RenameAccountCommand}" />
              <MenuItem Header="Удалить" Command="{Binding DeleteAccountCommand}" />
              <Separator/>
              <MenuItem Header="Быстрый расход" Command="{Binding QuickExpenseCommand}" />
              <MenuItem Header="Быстрый доход" Command="{Binding QuickIncomeCommand}" />
            </ContextMenu>
          </DataGrid.ContextMenu>

          <DataGrid.Columns>
            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="300"/>
            <DataGridTextColumn Header="Валюта" Binding="{Binding CurrencyCode}" Width="80"/>
            
            <DataGridTemplateColumn Header="Баланс" Width="140">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Balance, StringFormat={}{0:N2}}"
                             Classes="amount"
                             VerticalAlignment="Center" Margin="4,0"/>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Header="Доп. валюта" Width="100">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding SecondaryCurrencyCode}"
                             IsVisible="{Binding IsMultiCurrency}"
                             VerticalAlignment="Center" Margin="4,0"/>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>

            <DataGridTemplateColumn Header="Доп. баланс" Width="120">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding SecondaryBalance, StringFormat={}{0:N2}}"
                             Classes="amount"
                             IsVisible="{Binding IsMultiCurrency}"
                             VerticalAlignment="Center" Margin="4,0"/>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
          </DataGrid.Columns>
    </DataGrid>

    <!-- Empty State -->
    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16"
                IsVisible="{Binding !Accounts.Count}">
      <StackPanel.IsVisible>
        <MultiBinding Converter="{x:Static BoolConverters.And}">
          <Binding Path="!Accounts.Count"/>
          <Binding Path="!IsLoading"/>
        </MultiBinding>
      </StackPanel.IsVisible>
      <Path Data="M19,3H5C3.89,3 3,3.89 3,5V19C3,20.1 3.9,21 5,21H19C20.1,21 21,20.1 21,19V5C21,3.89 20.1,3 19,3M19,19H5V5H19V19M17,17H7V15H17V17M17,13H7V11H17V13M17,9H7V7H17V9Z" 
            Fill="#9E9E9E" Opacity="0.15" Width="120" Height="120" Stretch="Uniform" HorizontalAlignment="Center"/>
      <TextBlock Text="Здесь пока нет счетов..." Classes="dim" FontSize="16" HorizontalAlignment="Center"/>
    </StackPanel>
  </Grid>
</UserControl>