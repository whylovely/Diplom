<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Client.ViewModels"
             xmlns:models="using:Client.Models"
             x:Class="Client.Views.JournalView"
             x:DataType="vm:JournalViewModel">

  <Grid RowDefinitions="Auto,Auto,*">

    <TextBlock Grid.Row="0" Text="Журнал операций" Classes="heading" Margin="0,0,0,16"/>

    <TextBox Grid.Row="1" Watermark="🔍 Поиск по описанию, счёту, категории..."
             Text="{Binding SearchText}"
             Width="450"
             HorizontalAlignment="Left"
             Margin="0,0,0,16"/>

    <DataGrid Grid.Row="2" ItemsSource="{Binding FilteredRows}"
              SelectedItem="{Binding SelectedRow}"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              BorderThickness="0"
              Background="Transparent"
              GridLinesVisibility="Horizontal">
              
        <DataGrid.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Удалить" Command="{Binding DeleteTransactionCommand}"/>
          </ContextMenu>
        </DataGrid.ContextMenu>

        <DataGrid.Columns>
          <DataGridTextColumn Header="Дата"
                              Binding="{Binding DateFormatted}"
                              Width="120" FontFamily="Fira Code, Consolas, monospace" />

          <DataGridTemplateColumn Header="Тип" Width="90">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate x:DataType="models:JournalRow">
                <TextBlock Text="{Binding TypeLabel}"
                           VerticalAlignment="Center"
                           Margin="4,0"
                           FontWeight="SemiBold"/>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTextColumn Header="Описание"
                              Binding="{Binding Description}"
                              Width="*"/>

          <DataGridTextColumn Header="Счёт"
                              Binding="{Binding AccountName}"
                              Width="150"/>

          <DataGridTemplateColumn Header="Куда" Width="120">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate x:DataType="models:JournalRow">
                <TextBlock Text="{Binding ToAccountName}"
                           IsVisible="{Binding IsTransfer}"
                           VerticalAlignment="Center"
                           Margin="4,0"/>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTextColumn Header="Категория"
                              Binding="{Binding CategoryName}"
                              Width="130"/>

          <DataGridTemplateColumn Header="Сумма" Width="160">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate x:DataType="models:JournalRow">
                <TextBlock Text="{Binding FormattedAmount}"
                           Classes="amount"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="4,0"
                           FontWeight="SemiBold"/>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
        </DataGrid.Columns>
    </DataGrid>

    <StackPanel Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16"
                IsVisible="{Binding !FilteredRows.Count}">
      <Path Data="M19,3H5C3.89,3 3,3.89 3,5V19C3,20.1 3.9,21 5,21H19C20.1,21 21,20.1 21,19V5C21,3.89 20.1,3 19,3M19,19H5V5H19V19M7,17V15H17V17H7M7,13V11H17V13H7M7,9V7H17V9H7Z" 
            Fill="#9E9E9E" Opacity="0.15" Width="120" Height="120" Stretch="Uniform" HorizontalAlignment="Center"/>
      <TextBlock Text="Журнал операций пуст..." Classes="dim" FontSize="16" HorizontalAlignment="Center"/>
    </StackPanel>

  </Grid>
</UserControl>