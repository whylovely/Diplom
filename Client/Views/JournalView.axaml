<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Client.ViewModels"
             xmlns:models="using:Client.Models"
             x:Class="Client.Views.JournalView"
             x:DataType="vm:JournalViewModel">

  <Grid RowDefinitions="Auto,Auto,*">

    <!-- Header -->
    <TextBlock Grid.Row="0" Text="Журнал операций" Classes="heading" Margin="0,0,0,16"/>

    <!-- Search -->
    <TextBox Grid.Row="1" Watermark="🔍 Поиск по описанию, счёту, категории..."
             Text="{Binding SearchText}"
             Width="450"
             HorizontalAlignment="Left"
             Margin="0,0,0,16"/>

    <!-- Journal Table -->
    <DataGrid Grid.Row="2" ItemsSource="{Binding FilteredRows}"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              BorderThickness="0"
              Background="Transparent"
              GridLinesVisibility="Horizontal">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Дата"
                              Binding="{Binding DateFormatted}"
                              Width="100"/>

          <DataGridTemplateColumn Header="Тип" Width="90">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate x:DataType="models:JournalRow">
                <TextBlock Text="{Binding TypeLabel}"
                           VerticalAlignment="Center"
                           Margin="4,0"
                           FontWeight="SemiBold"/>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTextColumn Header="Описание"
                              Binding="{Binding Description}"
                              Width="*"/>

          <DataGridTextColumn Header="Счёт"
                              Binding="{Binding AccountName}"
                              Width="150"/>

          <DataGridTemplateColumn Header="Куда" Width="120">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate x:DataType="models:JournalRow">
                <TextBlock Text="{Binding ToAccountName}"
                           IsVisible="{Binding IsTransfer}"
                           VerticalAlignment="Center"
                           Margin="4,0"/>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>

          <DataGridTextColumn Header="Категория"
                              Binding="{Binding CategoryName}"
                              Width="130"/>

          <DataGridTemplateColumn Header="Сумма" Width="160">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate x:DataType="models:JournalRow">
                <TextBlock Text="{Binding FormattedAmount}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="4,0"
                           FontWeight="SemiBold"/>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
        </DataGrid.Columns>
    </DataGrid>

  </Grid>
</UserControl>
