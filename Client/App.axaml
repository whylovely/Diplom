<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fluent="clr-namespace:Avalonia.Themes.Fluent;assembly=Avalonia.Themes.Fluent"
             xmlns:conv="using:Client.Converters"
             x:Class="Client.App">

  <Application.Styles>
    <fluent:FluentTheme />

    <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>

    <!-- ══ GLOBAL FONT ══════════════════════════════════════════ -->
    <Style Selector="TextBlock">
      <Setter Property="FontFamily" Value="Plus Jakarta Sans, Segoe UI, sans-serif"/>
    </Style>
    <Style Selector="TemplatedControl">
      <Setter Property="FontFamily" Value="Plus Jakarta Sans, Segoe UI, sans-serif"/>
    </Style>

    <!-- ══ WINDOW ═══════════════════════════════════════════════ -->
    <Style Selector="Window">
      <Setter Property="Background" Value="#080C1A"/>
      <Setter Property="Foreground" Value="#D8D8D8"/>
    </Style>

    <!-- ══ BUTTONS ══════════════════════════════════════════════ -->
    <Style Selector="Button">
      <Setter Property="Background" Value="#151A2E"/>
      <Setter Property="Foreground" Value="#D8D8D8"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="14,8"/>
      <Setter Property="BorderBrush" Value="#222845"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="Button:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#1E88C8"/>
      <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <!-- Accent button class -->
    <Style Selector="Button.accent">
      <Setter Property="Background">
        <Setter.Value>
          <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Color="#29B6F6" Offset="0"/>
            <GradientStop Color="#AA00FF" Offset="1"/>
          </LinearGradientBrush>
        </Setter.Value>
      </Setter>
      <Setter Property="Foreground" Value="#FFFFFF"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
      <Setter Property="Background">
        <Setter.Value>
          <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Color="#4FC3F7" Offset="0"/>
            <GradientStop Color="#CE93D8" Offset="1"/>
          </LinearGradientBrush>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Danger button class -->
    <Style Selector="Button.danger">
      <Setter Property="Background" Value="#1F0F1C"/>
      <Setter Property="Foreground" Value="#FF5252"/>
      <Setter Property="BorderBrush" Value="#FF5252"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#FF5252"/>
      <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <!-- ══ TEXT INPUTS ══════════════════════════════════════════ -->
    <Style Selector="TextBox">
      <Setter Property="Background" Value="#0D1120"/>
      <Setter Property="Foreground" Value="#D8D8D8"/>
      <Setter Property="BorderBrush" Value="#222845"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="10,8"/>
    </Style>
    <Style Selector="TextBox:focus /template/ Border">
      <Setter Property="BorderBrush" Value="#1E88C8"/>
    </Style>

    <Style Selector="ComboBox">
      <Setter Property="Background" Value="#0D1120"/>
      <Setter Property="Foreground" Value="#D8D8D8"/>
      <Setter Property="BorderBrush" Value="#222845"/>
      <Setter Property="CornerRadius" Value="8"/>
    </Style>

    <Style Selector="DatePicker">
      <Setter Property="Foreground" Value="#E0E0E0"/>
    </Style>

    <Style Selector="NumericUpDown">
      <Setter Property="Background" Value="#0D1120"/>
      <Setter Property="Foreground" Value="#D8D8D8"/>
      <Setter Property="BorderBrush" Value="#222845"/>
      <Setter Property="CornerRadius" Value="8"/>
    </Style>

    <Style Selector="CheckBox">
      <Setter Property="Foreground" Value="#E0E0E0"/>
    </Style>

    <!-- ══ RADIO BUTTONS ═══════════════════════════════════════ -->
    <Style Selector="RadioButton">
      <Setter Property="Foreground" Value="#E0E0E0"/>
    </Style>

    <!-- ══ SEPARATOR ═══════════════════════════════════════════ -->
    <Style Selector="Separator">
      <Setter Property="Background" Value="#222845"/>
      <Setter Property="Height" Value="1"/>
      <Setter Property="Margin" Value="0,4"/>
    </Style>

    <!-- ══ DATAGRID ════════════════════════════════════════════ -->
    <Style Selector="DataGrid">
      <Setter Property="Background" Value="#0A0E1E"/>
      <Setter Property="Foreground" Value="#D8D8D8"/>
      <Setter Property="BorderBrush" Value="#222845"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="RowBackground" Value="Transparent"/>
      <Setter Property="GridLinesVisibility" Value="Horizontal"/>
      <Setter Property="HorizontalGridLinesBrush" Value="#151A2E"/>
    </Style>
    <Style Selector="DataGridRow:pointerover /template/ Rectangle#BackgroundRectangle">
      <Setter Property="Fill" Value="#1E88C815"/>
    </Style>
    <Style Selector="DataGridColumnHeader">
      <Setter Property="Background" Value="#0D1120"/>
      <Setter Property="Foreground" Value="#888888"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Padding" Value="10,8"/>
    </Style>

    <!-- ══ EXPANDER ════════════════════════════════════════════ -->
    <Style Selector="Expander">
      <Setter Property="Background" Value="#0D1120"/>
      <Setter Property="Foreground" Value="#D8D8D8"/>
      <Setter Property="BorderBrush" Value="#222845"/>
      <Setter Property="CornerRadius" Value="8"/>
    </Style>

    <!-- ══ CONTEXT MENU ═══════════════════════════════════════ -->
    <Style Selector="ContextMenu">
      <Setter Property="Background" Value="#151A2E"/>
      <Setter Property="BorderBrush" Value="#222845"/>
      <Setter Property="CornerRadius" Value="8"/>
    </Style>
    <Style Selector="MenuItem">
      <Setter Property="Foreground" Value="#D8D8D8"/>
    </Style>
    <Style Selector="MenuItem:pointerover /template/ Border">
      <Setter Property="Background" Value="#1E88C820"/>
    </Style>

    <!-- ══ SCROLLBAR ══════════════════════════════════════════ -->
    <Style Selector="ScrollBar">
      <Setter Property="Opacity" Value="0.5"/>
    </Style>

    <!-- ══ CARD STYLE CLASS ═══════════════════════════════════ -->
    <Style Selector="Border.card">
      <Setter Property="Background" Value="#B0111528"/>
      <Setter Property="CornerRadius" Value="16"/>
      <Setter Property="BorderBrush" Value="#222845"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="20"/>
    </Style>
    <!-- Card Hover Glow -->
    <Style Selector="Border.card:pointerover">
    </Style>

    <Style Selector="Border.cardSmall">
      <Setter Property="Background" Value="#B0111528"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="BorderBrush" Value="#222845"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="14"/>
    </Style>
    <Style Selector="Border.cardSmall:pointerover">
    </Style>

    <!-- ══ TEXT CLASSES ═══════════════════════════════════════ -->
    <Style Selector="TextBlock.heading">
      <Setter Property="FontSize" Value="24"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="TextBlock.subheading">
      <Setter Property="FontSize" Value="16"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="#E0E0E0"/>
    </Style>

    <Style Selector="TextBlock.dim">
      <Setter Property="Foreground" Value="#9E9E9E"/>
      <Setter Property="FontSize" Value="12"/>
    </Style>

    <!-- ══ SKELETON LOADING ═══════════════════════════════════ -->
    <Style Selector="Border.skeleton">
      <Setter Property="Background" Value="#151A2E"/>
      <Setter Property="CornerRadius" Value="4"/>
    </Style>
    <Style Selector="Border.skeleton.animating">
      <Style.Animations>
        <Animation Duration="0:0:1.5" IterationCount="Infinite">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="0.3"/>
          </KeyFrame>
          <KeyFrame Cue="50%">
            <Setter Property="Opacity" Value="0.7"/>
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="0.3"/>
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <Style Selector="TextBlock.moneyGreen">
      <Setter Property="FontFamily" Value="Fira Code, Consolas, monospace"/>
      <Setter Property="FontFeatures" Value="tnum, zero"/>
      <Setter Property="Foreground" Value="#00E676"/>
      <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style Selector="TextBlock.moneyRed">
      <Setter Property="FontFamily" Value="Fira Code, Consolas, monospace"/>
      <Setter Property="FontFeatures" Value="tnum, zero"/>
      <Setter Property="Foreground" Value="#FF5252"/>
      <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style Selector="TextBlock.amount">
      <Setter Property="FontFamily" Value="Fira Code, Consolas, monospace"/>
      <Setter Property="FontFeatures" Value="tnum, zero"/>
    </Style>

    <Style Selector="TextBlock.heroBalance">
      <Setter Property="FontFamily" Value="Fira Code, Consolas, monospace"/>
      <Setter Property="FontFeatures" Value="tnum, zero"/>
      <Setter Property="FontSize" Value="48"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Foreground">
        <Setter.Value>
          <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Color="#29B6F6" Offset="0" />
            <GradientStop Color="#AA00FF" Offset="1" />
          </LinearGradientBrush>
        </Setter.Value>
      </Setter>
    </Style>

    <Style Selector="TextBlock.cyan">
      <Setter Property="Foreground" Value="#29B6F6"/>
      <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <!-- ══ BOTTOM NAV BAR (MAC-OS DOCK) ITEMS ═════════════════════════════ -->
    <Style Selector="Button.dockItem">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="24"/>
      <Setter Property="Width" Value="48"/>
      <Setter Property="Height" Value="48"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Margin" Value="2,0"/>
      <Setter Property="Foreground" Value="#99D8D8D8"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.dockItem:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#10FFFFFF"/>
      <Setter Property="Foreground" Value="#D8D8D8"/>
    </Style>

    <!-- Active dock item -->
    <Style Selector="Button.navDock">
      <Setter Property="Background" Value="#20000000"/>
      <Setter Property="Foreground" Value="#5C9FD6"/>
    </Style>
    <Style Selector="Button.navDock /template/ ContentPresenter">
      <Setter Property="Background" Value="#20000000"/>
      <Setter Property="Foreground" Value="#5C9FD6"/>
    </Style>
    <Style Selector="Button.navDock:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#30000000"/>
      <Setter Property="Foreground" Value="#5C9FD6"/>
    </Style>

    <!-- Center Add Button -->
    <Style Selector="Button.dockCenterItem">
      <Setter Property="Background" Value="#1E88C8"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="24"/>
      <Setter Property="Width" Value="48"/>
      <Setter Property="Height" Value="48"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Margin" Value="6,0"/>
      <Setter Property="Foreground" Value="#FFFFFF"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.dockCenterItem:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#29B6F6"/>
      <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

  </Application.Styles>
</Application>